def telegram_mode_command(text):
    parts = text.strip().split()
    if len(parts) == 1:
        return f"Mode: {trade_mode()} | Live enabled: {'YES' if live_trading_enabled() else 'NO'}"
    action = parts[1].lower()
    if action == "paper":
        config["safe_live_manual_session_confirmed"] = False
        data = set_trade_mode("PAPER", False)
        safe_append_event("TELEGRAM_MODE_PAPER", data)
        return "Mode switched to PAPER. Live trading disabled."
    if action != "live":
        return "Usage: /mode paper OR /mode live then /mode live CONFIRM"
    if len(parts) >= 3 and parts[2].upper() == "CONFIRM":
        if not safe_live_confirmation.get("pending") or _safe_now_ts() > float(safe_live_confirmation.get("expires", 0) or 0):
            return "Live confirmation expired. Send /mode live first."
        if position is not None:
            return "Live mode blocked: active position exists."
        if not safe_check_internet(force=True):
            return "Live mode blocked: internet offline."
        config["safe_live_manual_session_confirmed"] = True
        data = set_trade_mode("LIVE", True)
        safe_live_confirmation["pending"] = False
        safe_append_event("TELEGRAM_MODE_LIVE_CONFIRMED", data)
        return "LIVE mode enabled for this server session. Trade carefully."
    safe_live_confirmation["pending"] = True
    safe_live_confirmation["expires"] = _safe_now_ts() + _safe_config_float("safe_live_confirm_seconds", 60, 20, 300)
    return "LIVE mode confirmation required. Send exactly: /mode live CONFIRM within 60 seconds."


def handle_telegram_command(text):
    text = str(text or "").strip()
    command = text.split()[0].lower() if text else ""
    try:
        if command == "/start":
            start_bot()
            return "Bot start requested."
        if command == "/stop":
            stop_bot()
            return "Bot stop requested. Server and watchdog remain active."
        if command == "/status":
            return telegram_status_text()
        if command == "/pnl":
            return telegram_pnl_text()
        if command == "/closeall":
            return telegram_close_all()
        if command == "/restart":
            telegram_restart_process()
            return ""
        if command == "/mode":
            return telegram_mode_command(text)
        if command == "/logs":
            return telegram_logs_text()
        return "Commands: /start /stop /status /pnl /closeall /restart /mode /logs"
    except Exception as exc:
        safe_append_event("TELEGRAM_COMMAND_ERROR", {"command": text, "error": str(exc)})
        return f"Command error: {exc}"


def telegram_command_loop():
    gui_log("Telegram command listener started")
    while True:
        try:
            token = str(config.get("telegram_token", "") or "")
            chat_id = str(config.get("chat_id", "") or "")
            if token and chat_id:
                params = {
                    "timeout": 1,
                    "offset": int(safe_runtime.get("telegram_offset", 0) or 0),
                    "allowed_updates": json.dumps(["message"]),
                }
                url = f"https://api.telegram.org/bot{token}/getUpdates"
                response = requests.get(url, params=params, timeout=4)
                if response.ok:
                    for update in response.json().get("result", []):
                        safe_runtime["telegram_offset"] = max(int(safe_runtime.get("telegram_offset", 0) or 0), int(update.get("update_id", 0)) + 1)
                        message = update.get("message") or {}
                        update_chat_id = str((message.get("chat") or {}).get("id", ""))
                        if update_chat_id != chat_id:
                            continue
                        text = str(message.get("text") or "").strip()
                        if not text.startswith("/"):
                            continue
                        reply = handle_telegram_command(text)
                        if reply:
                            telegram_send_text(reply)
                else:
                    safe_runtime["last_telegram_error"] = f"HTTP {response.status_code}"
        except Exception as exc:
            safe_runtime["last_telegram_error"] = str(exc)[:180]
        time.sleep(_safe_config_float("telegram_command_poll_seconds", 4, 2, 30))


