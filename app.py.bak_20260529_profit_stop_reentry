def weighted_market_structure(df, signal):
    work = closed_indicator_df(df)
    if work is None or len(work) < 8:
        return {"bias": "NEUTRAL", "score": 0, "reason": "Market structure waiting"}
    recent = work.tail(8)
    highs = pd.to_numeric(recent["high"], errors="coerce").ffill()
    lows = pd.to_numeric(recent["low"], errors="coerce").ffill()
    closes = pd.to_numeric(recent["close"], errors="coerce").ffill()
    hh = float(highs.iloc[-1]) >= float(highs.iloc[-4])
    hl = float(lows.iloc[-1]) >= float(lows.iloc[-4])
    ll = float(lows.iloc[-1]) <= float(lows.iloc[-4])
    lh = float(highs.iloc[-1]) <= float(highs.iloc[-4])
    close_slope = float(closes.iloc[-1] - closes.iloc[-4])
    if hh and hl and close_slope > 0:
        bias = "UP"
    elif ll and lh and close_slope < 0:
        bias = "DOWN"
    else:
        bias = "NEUTRAL"
    signal_dir = _w_direction(signal)
    score = 8 if bias == signal_dir else 3 if bias == "NEUTRAL" else -5
    return {
        "bias": bias,
        "score": score,
        "higher_high": bool(hh),
        "higher_low": bool(hl),
        "lower_low": bool(ll),
        "lower_high": bool(lh),
        "reason": f"Structure {bias} | slope {close_slope:.2f}",
    }


