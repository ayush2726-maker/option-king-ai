        decision = globals().get("last_weighted_decision") or {}
        weighted_score = int(decision.get("score", 0) or 0)
        fake = int(decision.get("fake_breakout_probability", 0) or 0)
        min_weighted = int(_okai_config_float("trend_continuation_min_weighted_score", 78, 60, 95))
        max_fake = int(_okai_config_float("trend_continuation_max_fake_breakout", 30, 10, 60))
        if weighted_score < min_weighted:
            return False, f"weighted {weighted_score}<{min_weighted}"
        if fake > max_fake:
            return False, f"fake {fake}%>{max_fake}%"
        return True, f"weighted {weighted_score}/100 fake {fake}%"
    except Exception as exc:
        return False, f"weighted check error {str(exc)[:60]}"


def _trend_continuation_core_ok(df, signal, price):
    try:
        scores = core_bridge_scores_from_closed(df, price)
        if not scores:
            return False, "core score unavailable"
        signal_key = "ce" if str(signal).upper() == "CE" else "pe"
        score = int(scores.get(f"{signal_key}_score", 0) or 0)
        total = int(scores.get("score_total", 4) or 4)
        min_score = int(_okai_config_float("trend_continuation_min_core_score", core_bridge_min_score(bool(scores.get("gap_day"))), 3, 5))
        parts = scores.get(f"{signal_key}_parts", {}) or {}
        core_direction_ok = bool(parts.get("vwap") and parts.get("ema") and parts.get("supertrend"))
        if score < min_score:
            return False, f"core {score}/{total}<{min_score}"
        if not core_direction_ok:
            return False, "core direction missing VWAP/EMA/SuperTrend"
        if not (parts.get("candle") or parts.get("orb") or bool(scores.get("gap_day"))):
            return False, "core momentum missing candle/ORB"
        return True, f"core {score}/{total}"
    except Exception as exc:
        return False, f"core check error {str(exc)[:60]}"


def entry_timing_guard(df, signal, price, vwap, ema9):
    ok, reason = _OKAI_TREND_CONT_BASE_ENTRY_TIMING_GUARD(df, signal, price, vwap, ema9)
    if ok or not trend_continuation_enabled():
        return ok, reason

    reason_text = str(reason or "")
    if "VWAP/session average" not in reason_text and "EMA9" not in reason_text:
        return ok, reason

    try:
        if df is None or len(df) < 12 or not signal:
            return ok, reason
        closed = df.iloc[:-1].copy() if len(df) > 1 else df.copy()
        if len(closed) < 12:
            return ok, reason

        price = float(price)
        vwap = float(vwap)
        ema9 = float(ema9)
        atr = recent_atr_points(closed)
        max_ema_points = max(
            float(_okai_config_float("trend_continuation_max_ema_points", 28, 12, 80)),
            atr * float(_okai_config_float("trend_continuation_max_ema_atr", 1.8, 0.8, 5.0)),
        )
        max_vwap_points = max(
            float(_okai_config_float("trend_continuation_max_vwap_points", 130, 35, 250)),
            atr * float(_okai_config_float("trend_continuation_max_vwap_atr", 8.0, 2.0, 20.0)),
        )
        max_run = int(_okai_config_float("trend_continuation_max_same_run", 6, 2, 12))
        run = same_direction_run_count(closed, signal)
        last = closed.iloc[-1]

        if str(signal).upper() == "CE":
            ema_extension = price - ema9
            vwap_extension = price - vwap
            if ema_extension > max_ema_points:
                return False, f"{reason_text}; continuation blocked: EMA stretch {ema_extension:.1f}>{max_ema_points:.1f}"
            if vwap_extension > max_vwap_points:
                return False, f"{reason_text}; continuation blocked: VWAP stretch {vwap_extension:.1f}>{max_vwap_points:.1f}"
            if run > max_run:
                return False, f"{reason_text}; continuation blocked: {run} green candles"
            if float(last["close"]) < float(last["high"]) - (atr * 0.55):
                return False, "Timing blocked CE: last candle rejected from high"
        else:
            ema_extension = ema9 - price
            vwap_extension = vwap - price
            if ema_extension > max_ema_points:
                return False, f"{reason_text}; continuation blocked: EMA stretch {ema_extension:.1f}>{max_ema_points:.1f}"
            if vwap_extension > max_vwap_points:
                return False, f"{reason_text}; continuation blocked: VWAP stretch {vwap_extension:.1f}>{max_vwap_points:.1f}"
            if run > max_run:
                return False, f"{reason_text}; continuation blocked: {run} red candles"
            if float(last["close"]) > float(last["low"]) + (atr * 0.55):
                return False, "Timing blocked PE: last candle rejected from low"

        core_ok, core_reason = _trend_continuation_core_ok(df, signal, price)
        if not core_ok:
            return False, f"{reason_text}; continuation blocked: {core_reason}"
        weighted_ok, weighted_reason = _trend_continuation_weighted_ok()
        if not weighted_ok:
            return False, f"{reason_text}; continuation blocked: {weighted_reason}"

        allow_reason = (
            f"Trend continuation allowed {signal}: {core_reason}, {weighted_reason}, "
            f"EMA stretch {ema_extension:.1f}, VWAP stretch {vwap_extension:.1f}"
        )
        gui_log(allow_reason)
        return True, allow_reason
    except Exception as exc:
        return ok, f"{reason_text}; continuation check error {str(exc)[:80]}"


