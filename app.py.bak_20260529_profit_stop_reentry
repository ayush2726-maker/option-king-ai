def backtest_score(df, index, orb_high_value, orb_low_value, gap_day=False):
    if index < 2:
        return 0, 0
    row = df.iloc[index]
    c1 = df.iloc[index - 1]
    c2 = row
    price = float(row.get("close", 0) or 0)
    vwap = float(row.get("VWAP", row.get("vwap", price)) or price)
    ema9 = float(row.get("EMA9", row.get("ema9", price)) or price)
    ema21 = float(row.get("EMA21", row.get("ema21", price)) or price)
    st_dir = str(row.get("SUPERTREND_DIR", row.get("supertrend_dir", "")) or "").upper()
    direction = backtest_gap_day_direction(df) if gap_day else "FLAT"

    ce_score = 0
    pe_score = 0

    if price > vwap:
        ce_score += 1
    if st_dir == "UP":
        ce_score += 1
    if ema9 > ema21:
        ce_score += 1
    if _okai_20260525_legacy_orb_ok("CE", price, float(c2.get("close", price) or price), orb_high_value, orb_low_value, gap_day, direction):
        ce_score += 1
    if c1["close"] > c1["open"] and c2["close"] > c2["open"]:
        ce_score += 1

    if price < vwap:
        pe_score += 1
    if st_dir == "DOWN":
        pe_score += 1
    if ema9 < ema21:
        pe_score += 1
    if _okai_20260525_legacy_orb_ok("PE", price, float(c2.get("close", price) or price), orb_high_value, orb_low_value, gap_day, direction):
        pe_score += 1
    if c1["close"] < c1["open"] and c2["close"] < c2["open"]:
        pe_score += 1

    return ce_score, pe_score


