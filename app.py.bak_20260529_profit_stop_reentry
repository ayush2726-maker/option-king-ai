def weighted_dynamic_sl_percent(setup):
    base = volatility_sl_percent({
        "regime": setup.get("regime") or {},
        "probability": setup.get("confidence", 0),
        "quality_score": setup.get("score", 0),
    })
    risk = weighted_risk_level(setup)
    if risk == "HIGH":
        base += 2.0
    elif risk == "LOW":
        base -= 1.0
    return max(9.0, min(30.0, base))


def weighted_apply_suggestion(setup, decision, spot_price=None):
    signal = setup.get("signal") if decision.get("take_trade") else None
    trade_type = setup.get("trade_type", "NONE") if decision.get("take_trade") else "NONE"
    update_trade_suggestion(signal, trade_type, setup.get("score", 0), decision.get("confidence", 0), decision.get("reason", ""), spot_price)
