def _okai_cp_format_gemini_error(exc):
    status_code = None
    try:
        status_code = getattr(getattr(exc, "response", None), "status_code", None)
    except Exception:
        status_code = None
    text = str(exc)
    if status_code == 429 or "429" in text or "quota" in text.lower() or "rate" in text.lower():
        return "Gemini 429/rate-limit; no fallback trade"
    if "timed out" in text.lower() or "timeout" in text.lower():
        return "Gemini timeout; no fallback trade"
    return f"Gemini error; no fallback trade: {text[:120]}"


def _okai_cp_record_option_premium(signal, option):
    try:
        if not isinstance(option, dict):
            return
        symbol = str(option.get("symbol") or "")
        premium = float(option.get("premium", 0) or 0)
        if not symbol or premium <= 0:
            return
        now_ts = time.time()
        hist = strict_option_premium_history.setdefault(symbol, [])
        hist.append((now_ts, premium))
        strict_option_premium_history[symbol] = hist[-8:]
        signal_key = str(signal or "").upper()
        if signal_key in {"CE", "PE"}:
            sig_hist = strict_signal_premium_history.setdefault(signal_key, [])
            sig_hist.append((now_ts, premium, symbol))
            strict_signal_premium_history[signal_key] = sig_hist[-12:]
    except Exception:
        pass


def _okai_cp_option_premium_momentum_ok(signal, option, premium):
    try:
        symbol = str((option or {}).get("symbol") or "")
        current = float(premium or 0)
        if current <= 0:
            return False, "Option premium momentum missing: premium invalid"
        min_move = strict_option_premium_momentum_min_move() / 100.0
        symbol_hist = list(strict_option_premium_history.get(symbol, []))
        if len(symbol_hist) >= 2:
            previous = float(symbol_hist[-2][1])
            if current >= previous * (1 + min_move):
                return True, f"Option premium momentum OK: {previous:.2f}->{current:.2f}"
            return False, f"Option premium momentum weak: {previous:.2f}->{current:.2f}"
        signal_key = str(signal or "").upper()
        sig_hist = list(strict_signal_premium_history.get(signal_key, []))
        if len(sig_hist) >= 2:
            previous = float(sig_hist[-2][1])
            if current >= previous * (1 + min_move):
                return True, f"{signal_key} premium basket momentum OK: {previous:.2f}->{current:.2f}"
            return False, f"{signal_key} premium basket momentum weak: {previous:.2f}->{current:.2f}"
        return False, "Option premium momentum waiting for second tick"
    except Exception as exc:
        return False, f"Option premium momentum error: {str(exc)[:80]}"


