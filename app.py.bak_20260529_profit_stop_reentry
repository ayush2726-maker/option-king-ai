    if not _okai_core_context_ready_for_entry(signal):
        return _OKAI_CORE_CONTEXT_FIX_BASE_PLACE_PAPER_TRADE(signal, premium, trade_type, option)

    old_weighted = config.get("weighted_decision_engine_enabled")
    old_gemini = config.get("gemini_decision_layer_enabled")
    old_chain = config.get("option_chain_ai_enabled")
    try:
        config["weighted_decision_engine_enabled"] = False
        config["gemini_decision_layer_enabled"] = False
        config["option_chain_ai_enabled"] = False
        gui_log(
            f"CORE BRIDGE FINAL ENTRY PASS | {signal} FULL | "
            "context preserved; weighted/Gemini final block bypassed for paper entry"
        )
        return _OKAI_CORE_CONTEXT_FIX_BASE_PLACE_PAPER_TRADE(signal, premium, "FULL", option)
    finally:
        for key, old_value in (
            ("weighted_decision_engine_enabled", old_weighted),
            ("gemini_decision_layer_enabled", old_gemini),
            ("option_chain_ai_enabled", old_chain),
        ):
            if old_value is None:
                config.pop(key, None)
            else:
                config[key] = old_value


