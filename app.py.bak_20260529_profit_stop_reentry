def _okai_gemini_pause(reason, seconds):
    global strict_gemini_blocked_until, strict_gemini_block_reason
    strict_gemini_blocked_until = max(float(strict_gemini_blocked_until or 0), time.time() + float(seconds or 0))
    strict_gemini_block_reason = str(reason or "Gemini paused")
    gui_log(f"{strict_gemini_block_reason}; Gemini paused {int(seconds)}s")


def _okai_gemini_pause_reason():
    remaining = int(max(0, float(strict_gemini_blocked_until or 0) - time.time()))
    if remaining <= 0:
        return ""
    return f"{strict_gemini_block_reason or 'Gemini paused'} ({remaining}s left); local core bridge only"


def gemini_decision_layer(setup):
    global strict_last_gemini_request_at
    score = int(setup.get("score", 0) or 0)

    pause_reason = _okai_gemini_pause_reason()
    if pause_reason:
        return _okai_cp_wait_decision(setup, pause_reason, model="gemini-circuit-open")

    min_call_score = strict_gemini_min_call_score()
    if score < min_call_score:
        return _okai_cp_wait_decision(
            setup,
            f"Gemini skipped: score {score}<{min_call_score:.0f}; local core bridge can still approve",
            model="gemini-skip-low-score",
        )
    if not gemini_decision_enabled():
        return _okai_cp_wait_decision(setup, "Gemini layer OFF; local core bridge only", model="gemini-off")
    if not external_gemini_enabled():
        return _okai_cp_wait_decision(setup, "External Gemini OFF; local core bridge only", model="gemini-external-off")
    if not str(config.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY") or "").strip():
        return _okai_cp_wait_decision(setup, "Gemini key missing; local core bridge only", model="gemini-key-missing")

    cache_key = weighted_setup_cache_key(setup)
    cache_ttl = max(30.0, float(weighted_gemini_cache_seconds() or 300))
    cached_ok = (
        strict_gemini_quality_cache.get("key") == cache_key
        and strict_gemini_quality_cache.get("decision")
        and time.time() - float(strict_gemini_quality_cache.get("timestamp", 0) or 0) <= cache_ttl
    )
    if cached_ok:
        cached = dict(strict_gemini_quality_cache.get("decision") or {})
        cached["reason"] = "cached Gemini | " + str(cached.get("reason", ""))
        return _okai_cp_normalize_gemini_decision(setup, cached, "cached Gemini")

    cooldown = strict_gemini_request_cooldown_seconds()
    elapsed = time.time() - float(strict_last_gemini_request_at or 0)
    if elapsed < cooldown:
        return _okai_cp_wait_decision(
            setup,
            f"Gemini request cooldown active {cooldown - elapsed:.0f}s; local core bridge only",
            model="gemini-cooldown",
        )

    holder = {"decision": None, "error": None}

    def _worker():
        try:
            holder["decision"] = call_gemini_quality_filter_sync(setup)
        except Exception as exc:
            holder["error"] = exc

    strict_last_gemini_request_at = time.time()
    thread = threading.Thread(target=_worker, name="okai-gemini-circuit-quality", daemon=True)
    thread.start()
    thread.join(weighted_gemini_timeout_seconds())

    if thread.is_alive():
        _okai_gemini_pause("Gemini timeout", gemini_timeout_pause_seconds())
        return _okai_cp_wait_decision(
            setup,
            f"Gemini timeout after {weighted_gemini_timeout_seconds():.1f}s; local core bridge only",
            model="gemini-timeout-circuit",
        )

    if holder.get("error") is not None:
        reason = _okai_cp_format_gemini_error(holder["error"])
        lower = reason.lower()
        if "429" in lower or "rate" in lower or "quota" in lower:
            _okai_gemini_pause("Gemini 429/rate-limit", gemini_rate_limit_pause_seconds())
        else:
            _okai_gemini_pause("Gemini API error", gemini_timeout_pause_seconds())
        return _okai_cp_wait_decision(setup, reason + "; local core bridge only", model="gemini-error-circuit")

    decision = _okai_cp_normalize_gemini_decision(setup, holder.get("decision"), "Gemini")
    decision["model"] = (holder.get("decision") or {}).get("model", decision.get("model", "gemini"))
    strict_gemini_quality_cache.update({
        "key": cache_key,
        "decision": json_safe(decision),
        "timestamp": time.time(),
    })
    return decision


