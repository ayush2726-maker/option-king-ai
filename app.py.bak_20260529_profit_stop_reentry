        f"LIVE ORDER SEND | {transaction_type} {params['tradingsymbol']} | "
        f"Qty {qty} | Product {params['producttype']} | {reason}"
    )
    try:
        response = obj.placeOrderFullResponse(params)
    except Exception as exc:
        raise RuntimeError(f"Angel live order failed: {exc}") from exc
    if not isinstance(response, dict) or not response.get("status"):
        raise RuntimeError(f"Angel live order rejected: {str(response)[:300]}")
    order_id = ((response.get("data") or {}).get("orderid") or response.get("orderid") or "")
    if not order_id:
        raise RuntimeError(f"Angel live order missing order id: {str(response)[:300]}")
    gui_log(f"LIVE ORDER OK | {transaction_type} | Order ID {order_id}")
    return str(order_id), response, params


