    atr_raw, atr_reason = weighted_atr_volatility_component(snapshot, regime)

    components = {
        "orb_breakout": {
            "score": weighted_component_score(orb_raw, 20, weights["orb_breakout"]),
            "weight": weights["orb_breakout"],
            "reason": orb_reason,
        },
        "vwap_alignment": {
            "score": weighted_component_score(vwap_raw, 15, weights["vwap_alignment"]),
            "weight": weights["vwap_alignment"],
            "reason": vwap_reason,
        },
        "ema_alignment": {
