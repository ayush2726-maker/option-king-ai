    work = closed_indicator_df(df)
    if work is None or len(work) < 8:
        return {"active": False, "score_penalty": 0, "reason": "Expiry, waiting for enough data"}
    near_vwap = abs(snapshot.get("close", 0) - snapshot.get("vwap", 0)) <= max(snapshot.get("atr", 0) * 0.22, 4)
    wick_heavy = max(snapshot.get("upper_wick_ratio", 0), snapshot.get("lower_wick_ratio", 0)) >= 0.48
    volatile = snapshot.get("atr_percent", 0) >= 0.16 or "HIGH_VOLATILITY" in str(regime.get("regime", ""))
    active = bool((near_vwap and wick_heavy) or (near_vwap and volatile))
    penalty = 10 if active else 2 if volatile else 0
    return {
        "active": active,
        "score_penalty": penalty,
        "near_vwap": bool(near_vwap),
