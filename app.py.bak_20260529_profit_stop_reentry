def gemini_decision_layer(setup):
    fallback = score_based_trade_decision(setup)
    if not gemini_decision_enabled():
        fallback["reason"] = "Gemini layer OFF; score fallback used: " + fallback.get("reason", "")
        return fallback
    if int(setup.get("score", 0) or 0) < weighted_min_entry_score():
        fallback["reason"] = "Gemini skipped for low score; " + fallback.get("reason", "")
        return fallback
    if not external_gemini_enabled():
        fallback["reason"] = "External Gemini OFF; score fallback used: " + fallback.get("reason", "")
        return fallback
    if not str(config.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY") or "").strip():
        fallback["reason"] = "Gemini key missing; score fallback used: " + fallback.get("reason", "")
        return fallback

    cache_key = weighted_setup_cache_key(setup)
    cache_ttl = weighted_gemini_cache_seconds()
    if (
        cache_ttl > 0
        and last_gemini_quality_cache.get("key") == cache_key
        and last_gemini_quality_cache.get("decision")
        and time.time() - float(last_gemini_quality_cache.get("timestamp", 0) or 0) <= cache_ttl
    ):
        cached = dict(last_gemini_quality_cache.get("decision") or {})
        cached["reason"] = "cached Gemini quality filter | " + cached.get("reason", "")
        return enforce_weighted_execution_rules(setup, cached, "cached Gemini")

    holder = {"decision": None, "error": None}

    def _worker():
        try:
            holder["decision"] = call_gemini_quality_filter_sync(setup)
        except Exception as exc:
            holder["error"] = exc

    thread = threading.Thread(target=_worker, name="okai-gemini-quality-filter", daemon=True)
    thread.start()
    thread.join(weighted_gemini_timeout_seconds())

    if thread.is_alive():
        fallback["model"] = "score-based-timeout-fallback"
        fallback["reason"] = (
            f"Gemini timeout after {weighted_gemini_timeout_seconds():.1f}s; "
            f"score fallback used: {fallback.get('reason', '')}"
        )
        return fallback if weighted_allow_score_fallback_on_ai_timeout() else {
            "take_trade": False,
            "signal": "WAIT",
            "confidence": 0,
            "entry_type": "NONE",
            "risk": weighted_risk_level(setup),
            "fake_breakout_probability": int(setup.get("fake_breakout_probability", 0) or 0),
            "reason": "Gemini timeout and score fallback disabled",
            "model": "gemini-timeout",
        }

    if holder.get("error") is not None:
        fallback["model"] = "score-based-error-fallback"
        fallback["reason"] = f"Gemini error fallback: {holder['error']} | {fallback.get('reason', '')}"
        return fallback

    decision = enforce_weighted_execution_rules(setup, holder.get("decision"), "Gemini")
    decision["model"] = (holder.get("decision") or {}).get("model", decision.get("model", "gemini"))
    last_gemini_quality_cache.update({
        "key": cache_key,
        "decision": json_safe(decision),
        "timestamp": time.time(),
    })
    return decision


