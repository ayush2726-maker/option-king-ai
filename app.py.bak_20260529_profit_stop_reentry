def safety_market_time_block_reason(now_dt=None):
    now_dt = now_dt or market_now()
    now = now_dt.time()
    if now < _safe_time_hhmm(config.get("safe_opening_block_until", "09:25"), "09:25"):
        return "opening spike chaos window blocked"
    if _safe_config_bool("safe_lunch_sideways_block_enabled", True) and _safe_time_in_window(
        now,
        config.get("safe_lunch_block_start", "11:45"),
        config.get("safe_lunch_block_end", "13:15"),
    ):
        return "lunch sideways window blocked"
    if is_expiry_day() and _safe_config_bool("safe_expiry_manipulation_block_enabled", True) and _safe_time_in_window(
        now,
        config.get("safe_expiry_manipulation_start", "14:30"),
        get_trade_end_time().strftime("%H:%M"),
    ):
        return "expiry manipulation zone blocked"
    windows = config.get("safe_trading_windows")
    if isinstance(windows, list) and windows:
        allowed = False
        for item in windows:
            if isinstance(item, (list, tuple)) and len(item) >= 2:
                allowed = allowed or _safe_time_in_window(now, item[0], item[1])
            elif isinstance(item, dict):
                allowed = allowed or _safe_time_in_window(now, item.get("start"), item.get("end"))
        if not allowed:
            return "outside configured safe trading windows"
    return ""


def safety_trade_limits_block_reason():
    now = _safe_now_ts()
    if now < float(safe_runtime.get("entry_cooldown_until", 0) or 0):
        return f"loss cooldown active for {_safe_duration(_safe_seconds_left(safe_runtime.get('entry_cooldown_until')))}"
    daily_stop = str(safe_runtime.get("daily_stop_reason") or "")
    if daily_stop:
        return daily_stop
    max_trades = _safe_config_int("safe_max_trades_per_day", 3, 1, 20)
    if trades_taken >= max_trades:
        return f"max trades per day reached ({trades_taken}/{max_trades})"
    max_losses = _safe_config_int("safe_max_consecutive_losses", 2, 1, 10)
    if loss_streak >= max_losses:
        cooldown = _safe_config_float("safe_loss_cooldown_minutes", 30, 1, 240) * 60
        safe_runtime["entry_cooldown_until"] = max(float(safe_runtime.get("entry_cooldown_until", 0) or 0), now + cooldown)
        return f"{loss_streak} consecutive losses; cooldown {_safe_duration(cooldown)}"
    daily_loss_amount = _safe_config_float("safe_daily_max_loss_amount", 0, 0, 10000000)
    daily_loss_percent = _safe_config_float("safe_daily_max_loss_percent", 3.0, 0, 100)
    limit_amount = daily_loss_amount if daily_loss_amount > 0 else paper_capital * (daily_loss_percent / 100.0)
    if limit_amount > 0 and daily_pnl <= -abs(limit_amount):
        reason = f"daily max loss reached ({daily_pnl:.2f} <= -{abs(limit_amount):.2f})"
        safe_runtime["daily_stop_reason"] = reason
        return reason
    return ""


def safe_entry_preflight(signal="", option=None, reason="entry"):
    if position is not None:
        return False, "active position lock: position already open"
    if not safe_check_internet():
        return False, "internet offline; new entries blocked"
    if _safe_now_ts() < float(safe_runtime.get("safety_pause_until", 0) or 0):
        return False, f"{safe_runtime.get('safety_pause_reason', 'safety pause')} ({_safe_duration(_safe_seconds_left(safe_runtime.get('safety_pause_until')))})"
    if position is not None and not safe_runtime.get("position_verified_after_reconnect", True):
        return False, "position not verified after reconnect"
    time_block = safety_market_time_block_reason()
    if time_block:
        return False, time_block
    limit_block = safety_trade_limits_block_reason()
    if limit_block:
        return False, limit_block
    if _safe_config_bool("websocket_feed_enabled", True) and not bool(safe_websocket_state.get("connected", False)):
        return False, f"websocket feed not ready: {safe_websocket_state.get('status')}"
    return True, "OK"


def build_order_signal_key(signal, trade_type, option=None, reason=""):
