# ===== OPTION KING AI PATCH: PEAK TRAIL AND PAPER STOP FILL =====
# Version: 2026.05.29-peak-trail-stopfill-1
#
# Fixes two paper-mode issues:
# 1) The charge-adjusted trailing override did not update position["peak"], so
#    a premium high such as 97.70 could fail to move the trailing stop.
# 2) Paper SL exits were filled at the next observed LTP. If the stop was 91.43
#    and the next poll was 88.80, the report showed 88.80. Paper mode now fills
#    at the stop level to simulate a stop order; live mode still uses market LTP.

SERVER_VERSION = "2026.05.29-peak-trail-stopfill-1"


def _okai_peak_trail_gap_percent():
    return _okai_config_float("trail_peak_gap_percent", 5.0, 1.0, 20.0)


def update_trailing_sl(*args, **kwargs):
    """Charge-adjusted + peak-percent trailing SL for long option paper/live positions."""
    global position
    if position is None:
        return

    entry = _okai_float(position.get("entry"))
    ltp = _okai_float(position.get("ltp", entry))
    old_sl = _okai_float(position.get("sl"))
    qty = _okai_int(position.get("qty"))

    if entry <= 0 or ltp <= 0 or qty <= 0:
        return

    old_peak = _okai_float(position.get("peak", entry), entry)
    if ltp > old_peak:
        position["peak"] = ltp
    peak = max(_okai_float(position.get("peak", entry), entry), entry, ltp)

    if "initial_risk" not in position:
        position["initial_risk"] = abs(entry - old_sl) if old_sl > 0 else entry * (_okai_float(globals().get("SL_PERCENT", 20)) / 100)
    initial_risk = max(_okai_float(position.get("initial_risk")), entry * 0.01)

    cost_lock, charges, buffer_amount = okai_charge_adjusted_cost_lock(entry, ltp, qty)

    if ltp >= cost_lock and _okai_float(position.get("sl")) < cost_lock:
        old = _okai_float(position.get("sl"))
        position["sl"] = cost_lock
        gui_log(
            f"SL moved to cost+charges+5% | Entry {entry:.2f} | "
            f"Charges/Qty {charges['per_qty']:.2f} | Buffer {buffer_amount:.2f} | "
            f"SL {old:.2f}->{position['sl']:.2f}"
        )

    profit = ltp - entry
    if profit >= initial_risk:
        gap_percent = _okai_peak_trail_gap_percent()
        risk_trail_sl = ltp - initial_risk
        peak_trail_sl = peak * (1 - gap_percent / 100)
        trail_sl = max(_okai_float(position.get("sl")), cost_lock, risk_trail_sl, peak_trail_sl)
        if trail_sl > _okai_float(position.get("sl")):
            old = _okai_float(position.get("sl"))
            position["sl"] = trail_sl
            gui_log(
                f"Trailing SL active after 1R/peak | {position.get('signal', '')} | "
                f"Peak {peak:.2f} | Gap {gap_percent:.1f}% | Risk {initial_risk:.2f} | "
                f"SL {old:.2f}->{position['sl']:.2f}"
            )


def _okai_paper_stop_fill_price(observed_ltp, stop_price):
    try:
        if position is not None and str(position.get("mode", "PAPER")).upper() == "PAPER":
            observed_ltp = _okai_float(observed_ltp)
            stop_price = _okai_float(stop_price)
            if stop_price > 0 and observed_ltp < stop_price:
                gui_log(f"Paper SL fill adjusted | Observed LTP {observed_ltp:.2f} | Stop {stop_price:.2f}")
                return stop_price
    except Exception:
        pass
    return observed_ltp


def manage_paper_trade(premium, current_price=None):
    global position
    if position is None:
        return
    try:
        position["ltp"] = premium
        try:
            save_position_tick(premium, current_price, "LTP")
        except Exception:
            pass

        old_signal = position.get("signal")
        reverse_exit, reverse_reason = should_exit_on_index_reversal(current_price)
        if reverse_exit:
            close_position(premium, reverse_reason)
            try_stop_and_reverse(old_signal, current_price, reverse_reason)
            return

        update_trailing_sl()
        sl_price = _okai_float(position.get("sl"))
        target_price = _okai_float(position.get("target"))

        if premium <= sl_price:
            close_position(_okai_paper_stop_fill_price(premium, sl_price), "SL HIT")
        elif target_price > 0 and premium >= target_price:
            if not extend_target_if_market_has_potential(current_price, premium):
                close_position(premium, "TARGET HIT")
        else:
            check_partial_exit()
    finally:
        try:
            if position is not None:
                save_active_position_state("trail_update")
            else:
                clear_active_position_state()
        except Exception as exc:
            safe_runtime["last_safe_error"] = f"manage_state: {exc}"


