def record_trade(exit_price, gross_pnl, charges, net_pnl, reason):
    quality = {}
    try:
        if isinstance(position, dict):
            quality = dict(position.get("trade_quality_snapshot") or {})
            quality.setdefault("grade", position.get("trade_quality", ""))
            quality.setdefault("entry_type", position.get("entry_type", ""))
            quality.setdefault("market_regime", position.get("market_regime", ""))
            quality.setdefault("premium_extension_percent", position.get("premium_extension_percent", 0.0))
            quality.setdefault("fake_breakout_probability", position.get("fake_breakout_probability", 0))
    except Exception:
        quality = {}

    result = _OKAI_QUALITY_BASE_RECORD_TRADE(exit_price, gross_pnl, charges, net_pnl, reason)

    try:
        pnl = _okai_quality_float(net_pnl, 0)
        entry_type = str(quality.get("entry_type") or "").upper()
        reason_text = str(reason or "")
        quality_runtime_stats["closed"] += 1
        if entry_type == "EARLY":
            quality_runtime_stats["early_entries"] += 1
            if pnl > 0:
                quality_runtime_stats["early_entry_wins"] += 1
        if "CHASE" in reason_text.upper() or _okai_quality_float(quality.get("premium_extension_percent"), 0) > _okai_config_float("trade_quality_max_premium_extension_percent", 12, 2, 60):
            quality_runtime_stats["chase_entries"] += 1
            if pnl <= 0:
                quality_runtime_stats["chase_entry_failures"] += 1
        if _okai_quality_int(quality.get("fake_breakout_probability"), 0) >= 25 or "FAKE" in reason_text.upper():
            quality_runtime_stats["fake_breakouts"] += 1
        if "TRAIL" in reason_text.upper():
            quality_runtime_stats["trailing_exits"] += 1
            quality_runtime_stats["profit_after_trailing_exit"] = round(
                _okai_quality_float(quality_runtime_stats.get("profit_after_trailing_exit"), 0) + pnl,
                2,
            )
        if pnl < 0:
            signal = str((position or {}).get("signal") or quality.get("signal") or "").upper()
            if signal in quality_failed_direction_until:
                cooldown = _okai_config_float("trade_quality_failed_direction_cooldown_minutes", 20, 1, 240) * 60
                quality_failed_direction_until[signal] = max(quality_failed_direction_until.get(signal, 0), time.time() + cooldown)
            loss_event = {
                "event": "LOSING_TRADE_ANALYSIS",
                "reason_trade_failed": reason_text,
                "net_pnl": pnl,
                "gross_pnl": gross_pnl,
                "charges": (charges or {}).get("total", 0) if isinstance(charges, dict) else charges,
                "market_regime": quality.get("market_regime", "--"),
                "entry_type": quality.get("entry_type", "--"),
                "trade_quality": quality.get("grade", "--"),
                "premium_extension_percent": quality.get("premium_extension_percent", 0.0),
                "fake_breakout_probability": quality.get("fake_breakout_probability", 0),
                "premium_move_percent": quality.get("premium_move_percent", 0.0),
                "quality_blocks_at_entry": quality.get("blocks", []),
                "symbol": (position or {}).get("option", {}).get("symbol", ""),
                "signal": (position or {}).get("signal", ""),
                "timestamp": market_now().isoformat(timespec="seconds"),
            }
            gui_log(
                "LOSING TRADE ANALYSIS | "
                f"Regime {loss_event['market_regime']} | Entry {loss_event['entry_type']} | "
                f"PremiumExt {loss_event['premium_extension_percent']}% | "
                f"Fake {loss_event['fake_breakout_probability']}% | Failed: {reason_text}"
            )
            _okai_quality_write_event(loss_event)
        else:
            _okai_quality_write_event({"event": "CLOSED_TRADE_ANALYSIS", "net_pnl": pnl, "reason": reason_text, **quality})
        if trade_history:
            trade_history[-1]["trade_quality"] = quality.get("grade", "")
            trade_history[-1]["entry_type"] = quality.get("entry_type", "")
            trade_history[-1]["market_regime"] = quality.get("market_regime", "")
            trade_history[-1]["premium_extension_percent"] = quality.get("premium_extension_percent", 0.0)
            trade_history[-1]["fake_breakout_probability"] = quality.get("fake_breakout_probability", 0)
    except Exception as exc:
        safe_runtime["last_safe_error"] = f"quality_record_trade: {exc}"
    return result


def backtest_signal(df, index, orb_high_value, orb_low_value, gap_day=False):
    signal, trade_type, score = _OKAI_QUALITY_BASE_BACKTEST_SIGNAL(df, index, orb_high_value, orb_low_value, gap_day)
    if not signal or not _safe_config_bool("trade_quality_gate_enabled", True):
        return signal, trade_type, score
    try:
        row = df.iloc[index]
        approved, quality = _okai_build_trade_quality(
            signal,
            premium=None,
            option=None,
            df=df.iloc[: index + 1].copy(),
            price=_okai_quality_float(row.get("close"), 0),
            require_premium=False,
            backtest=True,
        )
        if approved:
            return signal, "FULL", max(_okai_quality_int(score), _okai_quality_int(quality.get("score")))
        return None, "NONE", max(_okai_quality_int(score), _okai_quality_int(quality.get("score")))
    except Exception as exc:
        gui_log(f"Quality backtest signal error: {str(exc)[:120]}")
        return None, "NONE", score


