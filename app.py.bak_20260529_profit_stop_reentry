def get_qty(premium, trade_type, lot_size):
    qty = _OKAI_INTEL_BASE_GET_QTY(premium, trade_type, lot_size)
    if qty <= 0 or not intelligence_enabled() or not _okai_bool_config("dynamic_position_sizing_enabled", True):
        return qty
    try:
        context_ts = last_intelligence_context.get("timestamp")
        context_fresh = True
        if context_ts:
            context_fresh = (market_now() - dt.datetime.fromisoformat(context_ts)).total_seconds() <= 240
    except Exception:
        context_fresh = True
    if not context_fresh:
        return qty
    factor = float(last_intelligence_context.get("size_factor", 1.0) or 1.0)
    factor = max(0.35, min(1.0, factor))
    if factor >= 0.995:
        return qty
    try:
        lot_size = int(lot_size or FAST_LOT_SIZE)
        adjusted = int((qty * factor) // lot_size) * lot_size
        adjusted = max(lot_size, adjusted) if qty >= lot_size else 0
        if 0 < adjusted < qty:
            gui_log(f"Dynamic position sizing | Qty {qty}->{adjusted} | Factor {factor * 100:.0f}% | {last_intelligence_context.get('summary', '')}")
        return adjusted
    except Exception:
        return qty


def option_chain_ai_analysis(signal, option, premium, spot_price):
    try:
        strike = float((option or {}).get("strike") or 0)
        lot_size = int((option or {}).get("lot_size") or FAST_LOT_SIZE)
        premium = float(premium or 0)
        spot_price = float(spot_price or last_nifty_price or 0)
    except Exception:
        return {"approved": True, "score": 60, "reason": "Option chain check skipped"}
    if premium <= 0 or strike <= 0 or spot_price <= 0:
        return {"approved": False, "score": 0, "reason": "Option chain AI: missing option premium/strike/spot"}
    distance = abs(strike - spot_price)
    atm_distance_limit = _okai_config_float("option_chain_max_distance_points", 180, 25, 500)
    score = 70
    notes = []
    if distance <= 60:
        score += 12
        notes.append("ATM/near ATM")
    elif distance > atm_distance_limit:
        score -= 25
        notes.append(f"far strike {distance:.0f} pts")
    if is_expiry_day() and distance <= 80:
        score += 8
        notes.append("expiry ATM/ITM preference")
    min_quality_premium = _okai_config_float("option_chain_min_quality_premium", 30, 1, 300)
    if is_expiry_day():
        min_quality_premium = max(min_quality_premium, _okai_config_float("expiry_min_premium", 50, 1, 300))
    if premium < min_quality_premium:
        score -= 20
        notes.append(f"premium below quality floor {min_quality_premium:.0f}")
    affordable_qty, affordable_lots = get_max_affordable_qty(premium, lot_size)
    if affordable_lots < 1:
        return {"approved": False, "score": 0, "reason": "Option chain AI: not affordable"}
    if affordable_lots >= 3:
        score += 5
    score = max(0, min(100, score))
    min_score = _okai_config_float("option_chain_min_score", 55, 20, 95)
    approved = score >= min_score
    return {
        "approved": bool(approved),
        "score": score,
        "reason": "Option chain AI: " + (", ".join(notes) if notes else "quality OK"),
        "distance": round(distance, 2),
        "affordable_lots": affordable_lots,
    }


