            "weighted_components": setup.get("components", {}),
            "option_chain": setup.get("option_chain", {}),
            "oi_buildup": setup.get("oi_buildup", {}),
            "gemini_decision": decision,
            "reason": decision.get("reason", ""),
            "summary": (
                f"{'BUY ' + setup.get('signal_name', '') if decision.get('take_trade') else 'WAIT'} | "
                f"Score {setup.get('score', 0)}/100 | Confidence {decision.get('confidence', 0)}% | "
                f"{decision.get('entry_type', 'NONE')} | {setup.get('market_regime', 'UNKNOWN')}"
