def _okai_qg_vwap_retest(signal, df):
    try:
        work = prepare_weighted_backtest_df(df)
        work = closed_indicator_df(work)
        if work is None or len(work) < 8:
            return False, "VWAP retest waiting for enough closed candles"
        last = work.iloc[-1]
        prev = work.iloc[-2]
        recent = work.tail(7)
        close = float(last.get("close", 0) or 0)
        open_ = float(last.get("open", close) or close)
        vwap = float(last.get("VWAP", last.get("vwap", close)) or close)
        atr = max(float(recent_atr_points(work, 14) or 0), 1.0)
        tol = max(atr * 0.25, 4.0)
        prev_high = float(prev.get("high", close) or close)
        prev_low = float(prev.get("low", close) or close)
        sig = str(signal or "").upper()
        if sig == "CE":
            touched = any(float(row.get("low", close) or close) <= float(row.get("VWAP", row.get("vwap", vwap)) or vwap) + tol for _, row in recent.iterrows())
            reclaimed = close > vwap and (close > prev_high or close > open_)
            if touched and reclaimed:
                return True, "VWAP retest/reclaim confirmed"
            return False, "CE blocked: no VWAP retest/reclaim"
        if sig == "PE":
            touched = any(float(row.get("high", close) or close) >= float(row.get("VWAP", row.get("vwap", vwap)) or vwap) - tol for _, row in recent.iterrows())
            rejected = close < vwap and (close < prev_low or close < open_)
            if touched and rejected:
                return True, "VWAP retest/rejection confirmed"
            return False, "PE blocked: no VWAP retest/rejection"
    except Exception as exc:
        return False, f"VWAP retest check error: {str(exc)[:80]}"
    return False, "No signal"


def _okai_qg_chase_block(signal, snapshot):
    sig = str(signal or "").upper()
    close = float(snapshot.get("close", 0) or 0)
    vwap = float(snapshot.get("vwap", close) or close)
    atr = max(float(snapshot.get("atr", 0) or 0), 1.0)
    close_pos = float(snapshot.get("close_pos", 0.5) or 0.5)
    upper_wick = float(snapshot.get("upper_wick_ratio", 0) or 0)
    lower_wick = float(snapshot.get("lower_wick_ratio", 0) or 0)
    stretch = max(atr * 2.8, 22.0)
    if sig == "CE":
        if close - vwap > stretch and close_pos >= 0.82:
            return f"CE chase blocked: price stretched {close - vwap:.1f} above VWAP"
        if upper_wick >= 0.48:
            return "CE peak/rejection wick blocked"
    if sig == "PE":
        if vwap - close > stretch and close_pos <= 0.18:
            return f"PE chase blocked: price stretched {vwap - close:.1f} below VWAP"
        if lower_wick >= 0.48:
            return "PE bottom/rejection wick blocked"
    return ""


def _okai_qg_apply_quality_guard(setup):
    signal = str(setup.get("signal") or "").upper()
    if signal not in {"CE", "PE"}:
        return setup
    direction = _okai_qg_signal_direction(signal)
    snapshot = setup.get("snapshot") or {}
    components = setup.get("components") or {}
    mtf = setup.get("multi_timeframe") or {}
    score = int(setup.get("score", 0) or 0)
    blocks = []

    close = float(snapshot.get("close", 0) or 0)
    vwap = float(snapshot.get("vwap", close) or close)
    if signal == "CE" and close <= vwap:
        blocks.append("CE blocked: price not above VWAP")
    if signal == "PE" and close >= vwap:
        blocks.append("PE blocked: price not below VWAP")

    mtf_bias = str(mtf.get("bias", "NEUTRAL") or "NEUTRAL").upper()
    if mtf_bias not in {"NEUTRAL", direction}:
        blocks.append(f"MTF opposite ({mtf_bias})")
    elif mtf_bias == "NEUTRAL" and score < 85:
        blocks.append("MTF neutral; need strong score 85+")

    retest_ok = bool(setup.get("vwap_retest_ok"))
    if not retest_ok and score < 88:
        blocks.append(setup.get("vwap_retest_reason") or "VWAP retest missing")

    chase = _okai_qg_chase_block(signal, snapshot)
    if chase:
        blocks.append(chase)

    volume_score = int((components.get("volume_spike") or {}).get("score", 0) or 0)
    if volume_score <= 0 and score < 85:
        blocks.append("Volume weak; need strong score 85+")

    setup["quality_guard"] = {
        "passed": not blocks,
        "blocks": blocks,
        "vwap_retest_ok": retest_ok,
        "vwap_retest_reason": setup.get("vwap_retest_reason", ""),
        "mtf_bias": mtf_bias,
    }
    if blocks:
        setup["entry_type"] = "NONE"
        setup["trade_type"] = "NONE"
        setup["size_factor"] = 0.0
        setup["take_trade"] = False
        setup["quality_block_reason"] = "; ".join(blocks[:4])
        setup["reason"] = f"{setup.get('reason', '')} | QUALITY BLOCK: {setup['quality_block_reason']}".strip()
    return setup


