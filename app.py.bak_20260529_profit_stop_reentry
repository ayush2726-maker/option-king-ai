        candidates = [ce_setup, pe_setup]
        best = sorted(
            candidates,
            key=lambda setup: (int(setup.get("score", 0) or 0), int(setup.get("confidence", 0) or 0)),
            reverse=True,
        )[0]
        other = pe_setup if best.get("signal") == "CE" else ce_setup

        decision = score_based_trade_decision(best)
        signal = str(best.get("signal", "") or "").upper()
        meta = {
            "ai_score": int(best.get("score", 0) or 0),
            "ai_confidence": int(best.get("confidence", 0) or 0),
            "ai_regime": str(best.get("market_regime", "") or ""),
            "ai_entry_type": str(decision.get("entry_type", best.get("entry_type", "NONE")) or "NONE"),
            "ai_fake_breakout_probability": int(best.get("fake_breakout_probability", 0) or 0),
            "ai_reason": str(decision.get("reason", best.get("reason", "")) or "")[:260],
