def get_signal(price):
    global last_confidence, last_signal, last_score, last_intelligence_context, last_weighted_decision
    if not weighted_engine_enabled():
        return _OKAI_WEIGHTED_BASE_GET_SIGNAL(price)

    df = get_indicators()
    if df is None or len(df) < 12:
        reason = "Weighted engine waiting for enough candle data"
        last_signal = "WAIT"
        last_confidence = 0
        last_score = 0
        last_weighted_decision = {
            "enabled": True,
            "score": 0,
            "signal": "WAIT",
            "entry_type": "NONE",
            "confidence": 0,
            "market_regime": "DATA_WAIT",
            "fake_breakout_probability": 0,
            "reason": reason,
            "timestamp": market_now().isoformat(timespec="seconds"),
        }
        last_intelligence_context = dict(last_weighted_decision)
        update_trade_suggestion(None, "NONE", 0, 0, reason, price)
        return None, "NONE", 0

    try:
        update_gap_day_mode(df)
    except Exception:
        pass

    setup = choose_weighted_candidate(df, price)
    decision = gemini_decision_layer(setup)
    context = weighted_intelligence_context(setup, decision)
    last_intelligence_context = context
    last_weighted_decision = json_safe({
        "enabled": True,
        "score": setup.get("score", 0),
        "signal": decision.get("signal", "WAIT"),
        "entry_type": decision.get("entry_type", setup.get("entry_type")),
        "confidence": decision.get("confidence", 0),
        "risk": decision.get("risk"),
        "market_regime": setup.get("market_regime"),
        "fake_breakout_probability": decision.get("fake_breakout_probability", 0),
        "reason": decision.get("reason", ""),
        "components": setup.get("components", {}),
        "gemini_decision": decision,
        "timestamp": market_now().isoformat(timespec="seconds"),
    })

    block_reason = ""
    if decision.get("take_trade"):
        block_reason = post_exit_wait_reason() or direction_reentry_block_reason(setup.get("signal"))
        if block_reason:
            decision["take_trade"] = False
            decision["signal"] = "WAIT"
            decision["reason"] = block_reason
            context["no_trade"] = block_reason
            context["gemini_decision"] = decision
            context["ai"] = decision

    weighted_apply_suggestion(setup, decision, price)
    write_learning_journal("WEIGHTED_DECISION", context)

    if decision.get("take_trade"):
        signal = setup.get("signal")
        trade_type = normalize_trade_type(setup.get("trade_type", "HALF"))
        last_signal = signal
        last_confidence = int(decision.get("confidence", 0) or 0)
        last_score = int(setup.get("score", 0) or 0)
        gui_log(
            f"Weighted decision approved | {signal} {trade_type} | "
            f"Score {last_score}/100 | Confidence {last_confidence}% | "
