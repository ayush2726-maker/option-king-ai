    except Exception:
        return dt.time.fromisoformat(str(default)[:5])


def _safe_time_in_window(now_time, start_text, end_text):
    start = _safe_time_hhmm(start_text, "09:15")
    end = _safe_time_hhmm(end_text, "15:30")
    if start <= end:
        return start <= now_time <= end
    return now_time >= start or now_time <= end


