def _okai_copy_core_entry_context(target, previous, signal, trade_type):
    try:
        if not isinstance(target, dict) or not isinstance(previous, dict):
            return target
        if not bool(previous.get("core_bridge")):
            return target
        if str(previous.get("signal", "")).upper() != str(signal or "").upper():
            return target
        if str(previous.get("trade_type", "")).upper() != str(trade_type or "").upper():
            return target
        for key in ("core_bridge", "score_total", "supertrend", "gap_day"):
            if key in previous:
                target[key] = previous[key]
        target["core_bridge_preserved"] = True
        target["reason"] = f"{target.get('reason', '')} | Core bridge context preserved".strip()
    except Exception:
        pass
    return target


def update_trade_suggestion(signal, trade_type, score, confidence, reason, spot_price=None, option=None):
    global last_trade_suggestion
    previous = dict(last_trade_suggestion or {}) if isinstance(last_trade_suggestion, dict) else {}
    suggestion = _OKAI_CORE_CONTEXT_FIX_BASE_UPDATE_TRADE_SUGGESTION(
        signal, trade_type, score, confidence, reason, spot_price, option
    )
    if option is not None and signal and trade_type:
        suggestion = _okai_copy_core_entry_context(suggestion, previous, signal, trade_type)
        last_trade_suggestion = suggestion
    return suggestion


def _okai_core_context_ready_for_entry(signal):
    try:
        suggestion = globals().get("last_trade_suggestion") or {}
        if not isinstance(suggestion, dict) or not bool(suggestion.get("core_bridge")):
            return False
        if str(suggestion.get("signal", "")).upper() != str(signal or "").upper():
            return False
        if str(suggestion.get("trade_type", "")).upper() != "FULL":
            return False
        score = int(suggestion.get("score", 0) or 0)
        total = int(suggestion.get("score_total", 4) or 4)
        min_score = core_bridge_min_score(bool(suggestion.get("gap_day")))
        return score >= min_score and total >= min_score
    except Exception:
        return False


