        return _OKAI_AI_BT_BASE_BACKTEST_SIGNAL(df, index, orb_high_value, orb_low_value, gap_day)
    finally:
        _okai_ai_bt_day_context = previous_context
        orb_high = previous_orb_high
        orb_low = previous_orb_low
        gap_day_mode = previous_gap_mode
        gap_day_direction = previous_gap_direction


