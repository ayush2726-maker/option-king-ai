def safe_last_float(row, name, default=0.0):
    try:
        value = row.get(name, default)
        if pd.isna(value):
            return float(default)
        return float(value)
    except Exception:
        return float(default)


def market_regime_detection(df):
    work = closed_indicator_df(df)
    if work is None or len(work) < 12:
        return {
            "regime": "DATA_WAIT",
            "direction": "NEUTRAL",
            "atr": 0.0,
            "atr_percent": 0.0,
            "reason": "Waiting for enough candles",
        }
    last = work.iloc[-1]
    close = safe_last_float(last, "close")
    ema9 = safe_last_float(last, "EMA9", close)
    ema21 = safe_last_float(last, "EMA21", close)
    vwap = safe_last_float(last, "VWAP", close)
    st_dir = str(last.get("SUPERTREND_DIR") or "NEUTRAL")
    atr = recent_atr_points(work)
    atr_percent = (atr / close * 100) if close else 0.0
    ema_gap = abs(ema9 - ema21)
    vwap_distance = abs(close - vwap)
    lookback = work.tail(min(8, len(work)))
    slope = close - safe_last_float(lookback.iloc[0], "close", close)
    avg_range = float((lookback["high"] - lookback["low"]).mean() or 0)

    choppy = ema_gap < _okai_config_float("regime_min_ema_gap_points", MIN_EMA_GAP_POINTS, 0, 100) and vwap_distance < _okai_config_float("regime_min_vwap_distance_points", MIN_VWAP_DISTANCE_POINTS, 0, 100)
    high_vol = atr_percent > _okai_config_float("regime_high_volatility_atr_percent", 0.18, 0.02, 2.0) or avg_range > atr * 1.45

    if gap_day_mode:
        prefix = "GAP_UP" if gap_day_direction == "GAP UP" else "GAP_DOWN" if gap_day_direction == "GAP DOWN" else "GAP"
    else:
        prefix = ""

    if choppy:
        regime = "CHOPPY"
        direction = "NEUTRAL"
    elif st_dir == "UP" and ema9 > ema21 and slope > 0:
        regime = "TREND_UP"
        direction = "UP"
    elif st_dir == "DOWN" and ema9 < ema21 and slope < 0:
        regime = "TREND_DOWN"
        direction = "DOWN"
    elif high_vol:
        regime = "VOLATILE"
        direction = "UP" if slope > 0 else "DOWN" if slope < 0 else "NEUTRAL"
    else:
        regime = "MIXED"
        direction = "UP" if (ema9 > ema21 and slope >= 0) else "DOWN" if (ema9 < ema21 and slope <= 0) else "NEUTRAL"

    if prefix:
        regime = f"{prefix}_{regime}"
    return {
        "regime": regime,
        "direction": direction,
        "atr": round(float(atr), 2),
        "atr_percent": round(float(atr_percent), 4),
        "ema_gap": round(float(ema_gap), 2),
        "vwap_distance": round(float(vwap_distance), 2),
        "slope": round(float(slope), 2),
        "supertrend": st_dir,
        "reason": f"{regime} | ATR {atr:.2f} ({atr_percent:.3f}%) | EMA gap {ema_gap:.2f} | VWAP dist {vwap_distance:.2f}",
    }


def timeframe_trend_from_frame(frame):
    if frame is None or len(frame) < 6:
        return "NEUTRAL"
    close = pd.to_numeric(frame["close"], errors="coerce").dropna()
    if len(close) < 6:
        return "NEUTRAL"
    ema_fast = close.ewm(span=5).mean()
    ema_slow = close.ewm(span=13).mean()
    slope = float(close.iloc[-1] - close.iloc[-4])
    if float(ema_fast.iloc[-1]) > float(ema_slow.iloc[-1]) and slope > 0:
        return "UP"
    if float(ema_fast.iloc[-1]) < float(ema_slow.iloc[-1]) and slope < 0:
        return "DOWN"
    return "NEUTRAL"


def resample_timeframe(df, rule):
    if df is None or len(df) < 6:
        return None
    work = df.copy()
    try:
        work["dt"] = pd.to_datetime(work["time"], errors="coerce")
        work = work.dropna(subset=["dt"]).set_index("dt")
        if work.empty:
            return None
        return work.resample(rule).agg({
            "open": "first",
            "high": "max",
            "low": "min",
            "close": "last",
            "volume": "sum",
        }).dropna(subset=["close"])
    except Exception:
        return None


def multi_timeframe_trend(df):
    work = closed_indicator_df(df)
    if work is None or len(work) < 20:
        return {
            "bias": "NEUTRAL",
            "score": 0,
            "frames": {},
            "reason": "Waiting for multi-timeframe candles",
        }
    frames = {
        "1m": timeframe_trend_from_frame(work),
        "3m": timeframe_trend_from_frame(resample_timeframe(work, "3min")),
        "5m": timeframe_trend_from_frame(resample_timeframe(work, "5min")),
        "15m": timeframe_trend_from_frame(resample_timeframe(work, "15min")),
    }
    up_count = sum(1 for value in frames.values() if value == "UP")
    down_count = sum(1 for value in frames.values() if value == "DOWN")
    if up_count > down_count:
        bias = "UP"
        score = up_count - down_count
    elif down_count > up_count:
        bias = "DOWN"
        score = down_count - up_count
    else:
        bias = "NEUTRAL"
        score = 0
    return {
        "bias": bias,
        "score": int(score),
        "frames": frames,
        "reason": " | ".join(f"{key}:{value}" for key, value in frames.items()),
    }


def candle_quality_metrics(df, signal):
    work = closed_indicator_df(df)
    if work is None or len(work) < 8:
        return {"score": 0, "reason": "Candle data wait", "volume_ok": True}
    last = work.iloc[-1]
    prev = work.iloc[-2]
    close = safe_last_float(last, "close")
    open_ = safe_last_float(last, "open", close)
    high = safe_last_float(last, "high", close)
    low = safe_last_float(last, "low", close)
    body = abs(close - open_)
    candle_range = max(high - low, 0.01)
    body_ratio = body / candle_range
    close_pos = (close - low) / candle_range
    volume = safe_last_float(last, "volume", 0)
    avg_vol = float(pd.to_numeric(work.tail(6).iloc[:-1]["volume"], errors="coerce").fillna(0).mean() or 0)
    volume_ok = True if avg_vol <= 0 else volume > avg_vol

    score = 0
    notes = []
    if body_ratio >= 0.35:
        score += 25
    else:
        notes.append("small body")
    if signal == "CE":
        if close > open_:
            score += 20
        else:
            notes.append("not green")
        if close > safe_last_float(prev, "high", close):
            score += 20
        else:
            notes.append("no previous-high break")
        if close_pos >= 0.55:
            score += 15
        else:
            notes.append("weak close position")
    elif signal == "PE":
        if close < open_:
            score += 20
        else:
            notes.append("not red")
        if close < safe_last_float(prev, "low", close):
            score += 20
        else:
            notes.append("no previous-low break")
        if close_pos <= 0.45:
            score += 15
        else:
            notes.append("weak close position")
    if volume_ok:
        score += 20
    else:
        notes.append("volume below avg5")
    return {
        "score": min(100, int(score)),
        "body_ratio": round(body_ratio, 3),
        "volume": round(volume, 2),
        "avg_volume": round(avg_vol, 2),
        "volume_ok": bool(volume_ok),
        "reason": ", ".join(notes) if notes else "Candle quality OK",
    }


def learning_profile(signal):
    if not _okai_bool_config("self_learning_adjustment_enabled", True):
        return {"adjustment": 0, "summary": "Learning adjustment OFF"}
    try:
        rows = list(trade_history[-40:])
        if not rows:
            return {"adjustment": 0, "summary": "No learning history yet"}
        now_hour = market_now().hour
        related = [
            row for row in rows
            if str(row.get("signal", "")).upper() == str(signal).upper()
            and abs(int(str(row.get("time", "00:00")[:2] or 0)) - now_hour) <= 1
        ]
        if len(related) < 3:
            related = [row for row in rows if str(row.get("signal", "")).upper() == str(signal).upper()]
        if len(related) < 3:
            return {"adjustment": 0, "summary": "Learning sample small"}
        wins = sum(1 for row in related if float(row.get("pnl", 0) or 0) > 0)
        win_rate = wins / len(related)
        if win_rate < 0.45:
            return {"adjustment": -6, "summary": f"Learning caution: {signal} win-rate {win_rate * 100:.0f}% in similar trades"}
        if win_rate > 0.65:
            return {"adjustment": 3, "summary": f"Learning support: {signal} win-rate {win_rate * 100:.0f}% in similar trades"}
        return {"adjustment": 0, "summary": f"Learning neutral: {signal} win-rate {win_rate * 100:.0f}%"}
    except Exception as exc:
        return {"adjustment": 0, "summary": f"Learning skipped: {exc}"}


def probability_scoring(signal, trade_type, score, df, price):
    regime = market_regime_detection(df)
    mtf = multi_timeframe_trend(df)
    candle = candle_quality_metrics(df, signal)
    learning = learning_profile(signal)
    signal_dir = "UP" if signal == "CE" else "DOWN"
    regime_text = str(regime.get("regime", ""))

    probability = 38 + (int(score or 0) * 9)
    quality_score = 45 + int(score or 0) * 8
    notes = []

    if regime.get("direction") == signal_dir:
        probability += 10
        quality_score += 10
        notes.append("regime aligned")
    elif regime.get("direction") not in {"NEUTRAL", signal_dir}:
        probability -= 14
        quality_score -= 15
        notes.append("regime opposite")
    elif "CHOPPY" in regime_text:
        probability -= 12
        quality_score -= 15
        notes.append("choppy")

    if mtf.get("bias") == signal_dir:
        probability += 9 + min(4, int(mtf.get("score", 0) or 0) * 2)
        quality_score += 12
        notes.append("MTF aligned")
    elif mtf.get("bias") not in {"NEUTRAL", signal_dir}:
        probability -= 12
        quality_score -= 12
        notes.append("MTF opposite")

    candle_score = int(candle.get("score", 0) or 0)
    probability += round((candle_score - 60) / 6)
    quality_score += round((candle_score - 50) / 3)
    if candle_score < 55:
        notes.append(candle.get("reason", "weak candle"))

    probability += int(learning.get("adjustment", 0) or 0)
    if "VOLATILE" in regime_text:
        probability -= 4
        quality_score -= 4
        notes.append("volatile")

    probability = max(0, min(99, int(round(probability))))
    quality_score = max(0, min(100, int(round(quality_score))))
    return {
        "probability": probability,
        "quality_score": quality_score,
        "regime": regime,
        "mtf": mtf,
        "candle": candle,
        "learning": learning,
        "notes": notes,
    }


def ai_decision_layer(context):
    if not ai_decision_layer_enabled():
        return {"approved": True, "reason": "AI decision layer OFF", "model": "off"}
    probability = int(context.get("probability", 0) or 0)
    quality = int(context.get("quality_score", 0) or 0)
    regime_text = str((context.get("regime") or {}).get("regime", ""))
    notes = list(context.get("notes") or [])
    if "CHOPPY" in regime_text and probability < 82:
        return {"approved": False, "reason": "AI local layer: choppy regime needs 82%+ probability", "model": "local"}
    if quality < _okai_config_float("intelligence_min_quality_score", 58, 30, 95):
        return {"approved": False, "reason": f"AI local layer: trade quality too low ({quality})", "model": "local"}
    if probability < intelligence_min_probability():
        return {"approved": False, "reason": f"AI local layer: probability {probability}% below {intelligence_min_probability():.0f}%", "model": "local"}

    if external_openai_decision_enabled() and ai_client is not None:
        try:
            prompt = (
                "You are a conservative NIFTY options risk filter. "
                "Return JSON only with approved true/false and reason. "
                f"Context: {json.dumps(json_safe(context), ensure_ascii=False)[:2500]}"
            )
            res = ai_client.responses.create(
                model=str(config.get("ai_model", AI_MODEL) or AI_MODEL),
                input=prompt,
                temperature=0.0,
                max_output_tokens=120,
            )
            data = json.loads(res.output_text.strip())
            return {
                "approved": bool(data.get("approved")),
                "reason": str(data.get("reason", "OpenAI decision")),
                "model": str(config.get("ai_model", AI_MODEL) or AI_MODEL),
            }
        except Exception as exc:
            notes.append(f"external AI fallback: {exc}")

    return {"approved": True, "reason": "AI local layer approved" + (": " + ", ".join(notes[:3]) if notes else ""), "model": "local"}


def no_trade_logic(signal, trade_type, score, context):
    probability = int(context.get("probability", 0) or 0)
    quality = int(context.get("quality_score", 0) or 0)
    regime_text = str((context.get("regime") or {}).get("regime", ""))
    mtf_bias = str((context.get("mtf") or {}).get("bias", "NEUTRAL"))
    signal_dir = "UP" if signal == "CE" else "DOWN"
    if "DATA_WAIT" in regime_text:
        return False, "No-trade: waiting for enough regime data"
    if "CHOPPY" in regime_text and int(score or 0) < 5:
        return False, "No-trade: choppy market, score below 5"
    if mtf_bias not in {"NEUTRAL", signal_dir} and int((context.get("mtf") or {}).get("score", 0) or 0) >= 2:
        return False, f"No-trade: multi-timeframe trend opposite ({mtf_bias})"
    if probability < intelligence_min_probability():
        return False, f"No-trade: probability {probability}% below {intelligence_min_probability():.0f}%"
    if quality < _okai_config_float("intelligence_min_quality_score", 58, 30, 95):
        return False, f"No-trade: quality score {quality} too low"
    ai_gate = ai_decision_layer(context)
    context["ai"] = ai_gate
    if not ai_gate.get("approved"):
        return False, ai_gate.get("reason", "AI decision blocked")
    return True, "Trade quality passed"


def intelligence_size_factor(context):
    probability = int(context.get("probability", 0) or 0)
    quality = int(context.get("quality_score", 0) or 0)
    regime_text = str((context.get("regime") or {}).get("regime", ""))
    factor = 1.0
    if probability < 75:
        factor = 0.55
    elif probability < 84:
        factor = 0.75
    elif probability < 90:
        factor = 0.90
    if quality < 65:
        factor = min(factor, 0.65)
    if "VOLATILE" in regime_text:
        factor = min(factor, 0.75)
    if loss_streak > 0:
        factor = min(factor, 0.70)
    return max(0.35, min(1.0, factor))


def volatility_sl_percent(context):
    base = float(EXPIRY_SL_PERCENT if is_expiry_day() else SL_PERCENT)
    regime = context.get("regime") or {}
    atr_percent = float(regime.get("atr_percent", 0) or 0)
    regime_text = str(regime.get("regime", ""))
    if "VOLATILE" in regime_text or atr_percent > 0.18:
        base += 4.0
    elif "TREND" in regime_text and atr_percent < 0.10:
        base -= 2.0
    return max(10.0, min(28.0, base))


def build_intelligence_context(signal, trade_type, score, df, price):
