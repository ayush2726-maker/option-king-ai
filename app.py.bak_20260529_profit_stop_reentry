        if edge_grade == "STRONG":
            score_delta -= 2
            fake_delta += 2
            notes.append("late-session caution softened by proven edge")
        else:
            score_delta -= 5
            fake_delta += 5
            notes.append("late-session caution")

    score_delta += score_boost
    fake_delta -= fake_reduction

    adjusted_score = _okai_quality_int(quality.get("score"), 0) + score_delta
    adjusted_fake = max(0, _okai_quality_int(quality.get("fake_breakout_probability"), 0) + fake_delta)
    min_a_score = _okai_config_float("trade_quality_min_a_score", 70, 1, 100)
    max_fake_a = _okai_config_float("trade_quality_max_fake_a", 45, 5, 80)
    if not blocks:
        if adjusted_score < min_a_score:
            blocks.append(f"local learning score {adjusted_score}<{min_a_score:.0f}")
        if adjusted_fake > max_fake_a:
            blocks.append(f"local learning fake risk {adjusted_fake}%>{max_fake_a:.0f}")

    return {
        "enabled": True,
        "action": "BLOCK" if blocks else "PASS",
        "summary": "; ".join(notes[:5]) if notes else profile.get("summary", "Local learning active"),
        "blocks": list(dict.fromkeys(blocks))[:5],
        "score_penalty": min(score_delta, 0),
        "fake_penalty": max(fake_delta, 0),
        "score_boost": score_boost,
        "fake_reduction": fake_reduction,
        "adjusted_score": adjusted_score,
        "adjusted_fake_breakout_probability": adjusted_fake,
        "edge": edge,
        "edge_summary": profile.get("edge_summary", ""),
        "sample": profile.get("sample", 0),
    }


def _okai_edge_soft_block(text):
    text = str(text or "").lower()
    return (
        text.startswith("quality score ")
        or text.startswith("fake breakout ")
        or text.startswith("local learning score ")
        or text.startswith("local learning fake risk ")
    )


def _okai_build_trade_quality(signal, premium=None, option=None, df=None, price=None, require_premium=True, backtest=False):
    approved, quality = _OKAI_EDGE_BASE_BUILD_TRADE_QUALITY(signal, premium, option, df, price, require_premium, backtest)
    learning = quality.get("local_learning") if isinstance(quality, dict) else None
    if backtest or not isinstance(learning, dict) or not learning.get("enabled"):
        return approved, quality

    try:
        quality["score"] = learning.get("adjusted_score", quality.get("score"))
        quality["fake_breakout_probability"] = learning.get(
            "adjusted_fake_breakout_probability",
            quality.get("fake_breakout_probability"),
        )
        quality["edge_summary"] = learning.get("edge_summary", "")
        quality["edge_support"] = learning.get("edge", {})

        blocks = list(quality.get("blocks") or [])
        hard_blocks = [block for block in blocks if not _okai_edge_soft_block(block)]
        soft_blocks = [block for block in blocks if _okai_edge_soft_block(block)]

        allowed = set(_okai_quality_allowed_grades())
        score = _okai_quality_int(quality.get("score"), 0)
        fake = _okai_quality_int(quality.get("fake_breakout_probability"), 0)
        min_a_score = _okai_config_float("trade_quality_min_a_score", 70, 1, 100)
        max_fake_a = _okai_config_float("trade_quality_max_fake_a", 45, 5, 80)

        if soft_blocks and not hard_blocks and score >= min_a_score and fake <= max_fake_a:
            quality["blocks"] = []
            quality["grade"] = "A" if quality.get("grade") not in {"A+"} else quality.get("grade")
            approved = quality["grade"] in allowed
            quality["edge_upgrade"] = True
        elif not hard_blocks and approved:
            quality["edge_upgrade"] = bool(learning.get("score_boost") or learning.get("fake_reduction"))
        elif hard_blocks:
            quality["blocks"] = list(dict.fromkeys(hard_blocks + soft_blocks))[:8]
    except Exception as exc:
        quality["edge_learning_error"] = str(exc)[:120]
    return approved, quality


