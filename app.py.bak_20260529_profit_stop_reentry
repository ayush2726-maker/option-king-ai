def _okai_bool_config(name, default=False):
    return bool(config.get(name, default))


def _okai_gap_recovery_signal(price, vwap, ema9, ema21, supertrend_dir, c1, c2, ce_score, pe_score):
    if not gap_day_mode:
        return None
    try:
        c1_close = float(c1.get("close", price))
        c2_close = float(c2.get("close", price))
        c1_high = float(c1.get("high", price))
        c1_low = float(c1.get("low", price))
        c2_high = float(c2.get("high", price))
        c2_low = float(c2.get("low", price))
    except Exception:
        return None

    two_above_vwap = c1_close > vwap and c2_close > vwap and price > vwap
    two_below_vwap = c1_close < vwap and c2_close < vwap and price < vwap
    ce_reclaim = (
        _okai_bool_config("gap_recovery_ce_enabled", True)
        and gap_day_direction == "GAP DOWN"
        and two_above_vwap
        and supertrend_dir == "UP"
        and ema9 > ema21
        and (c2_close >= c1_high or c2_high > c1_high or price > c2_high)
        and ce_score >= 3
    )
    pe_breakdown = (
        _okai_bool_config("gap_breakdown_pe_enabled", True)
        and gap_day_direction == "GAP UP"
        and two_below_vwap
        and supertrend_dir == "DOWN"
        and ema9 < ema21
        and (c2_close <= c1_low or c2_low < c1_low or price < c2_low)
        and pe_score >= 3
    )
    if ce_reclaim:
        score = max(4, int(ce_score or 0))
        trade_type = "FULL" if _okai_bool_config("gap_recovery_full_amount", True) else "HALF"
        return {
            "signal": "CE",
            "trade_type": trade_type,
            "confidence": 90,
            "score": score,
            "reason": "Gap-down recovery CE: 2 candles above VWAP + Supertrend UP + EMA UP + high break; PE blocked",
        }
    if pe_breakdown:
        score = max(4, int(pe_score or 0))
        trade_type = "FULL" if _okai_bool_config("gap_recovery_full_amount", True) else "HALF"
        return {
            "signal": "PE",
            "trade_type": trade_type,
            "confidence": 90,
            "score": score,
            "reason": "Gap-up breakdown PE: 2 candles below VWAP + Supertrend DOWN + EMA DOWN + low break; CE blocked",
        }
    return None


def choose_rule_signal(price, vwap, ema9, ema21, trend, supertrend_dir, c1, c2, ce_score, pe_score):
    recovery = _okai_gap_recovery_signal(price, vwap, ema9, ema21, supertrend_dir, c1, c2, ce_score, pe_score)
    signal, trade_type, confidence, reason = _OKAI_LIVE_BASE_CHOOSE_RULE_SIGNAL(
        price, vwap, ema9, ema21, trend, supertrend_dir, c1, c2, ce_score, pe_score
    )
    if recovery:
        if recovery["signal"] == "CE" and _okai_bool_config("gap_recovery_block_pe", True):
            if signal == "PE" or not signal:
                return recovery["signal"], recovery["trade_type"], recovery["confidence"], recovery["reason"]
        if recovery["signal"] == "PE" and _okai_bool_config("gap_breakdown_block_ce", True):
            if signal == "CE" or not signal:
                return recovery["signal"], recovery["trade_type"], recovery["confidence"], recovery["reason"]
        if signal == recovery["signal"]:
            return recovery["signal"], recovery["trade_type"], max(confidence, recovery["confidence"]), recovery["reason"]
    return signal, trade_type, confidence, reason


_OKAI_LIVE_BASE_HANDLER_DO_POST = Handler.do_POST


def _okai_live_do_post(self):
    if not self.authorized():
        self.send_json({"ok": False, "error": "unauthorized"}, 401)
        return
    path = urlparse(self.path).path
    if path not in {"/mode", "/manual-order"}:
        return _OKAI_LIVE_BASE_HANDLER_DO_POST(self)
    body = self.read_body()
    try:
        if path == "/mode":
