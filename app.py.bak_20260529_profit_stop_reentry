def score_based_trade_decision(setup):
    score = int(setup.get("score", 0) or 0)
    confidence = int(setup.get("confidence", 0) or 0)
    fake = int(setup.get("fake_breakout_probability", 0) or 0)
    signal_name = str(setup.get("signal_name", "WAIT") or "WAIT").upper()
    entry_type = str(setup.get("entry_type", "NONE") or "NONE").upper()
    regime = str(setup.get("market_regime", "UNKNOWN") or "UNKNOWN").upper()
    min_entry = int(weighted_min_entry_score())
    reason = setup.get("reason", "Score-based weighted decision")
    take_trade = True

    if signal_name not in {"BUY_CALL", "BUY_PUT"}:
        take_trade = False
        reason = "No CALL/PUT setup selected"
    elif score < weighted_small_threshold():
        take_trade = False
        reason = f"Weighted score {score}/100 below no-trade floor {weighted_small_threshold():.0f}"
    elif score < min_entry:
        take_trade = False
        reason = f"Weighted score {score}/100 is watch-only; early entry starts at {min_entry}"
    elif confidence <= weighted_execute_confidence():
        take_trade = False
        reason = f"Confidence {confidence}% not above execution threshold {weighted_execute_confidence():.0f}%"
    elif fake > weighted_max_fake_breakout_probability():
        take_trade = False
        reason = f"Fake breakout probability {fake}% too high"
    elif weighted_is_sideways_regime(setup):
        take_trade = False
        reason = f"Market regime {regime} is sideways; no trade"
    elif regime == "EXPIRY_MANIPULATION" and (score < weighted_strong_threshold() or confidence < 88):
        take_trade = False
        reason = "Expiry manipulation risk requires strong score and 88% confidence"

    return {
        "take_trade": bool(take_trade),
        "signal": signal_name if take_trade else "WAIT",
        "confidence": int(confidence),
        "entry_type": entry_type if take_trade else "NONE",
        "risk": weighted_risk_level(setup),
        "fake_breakout_probability": int(fake),
        "reason": (f"{entry_type} {signal_name} score-based approval | {reason}" if take_trade else reason),
        "model": "score-based-weighted-rules",
    }


