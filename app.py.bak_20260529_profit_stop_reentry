def gap_directional_orb_mode(signal):
    """Return ACTIVE when ORB should matter for this gap-day direction."""
    sig = str(signal or "").upper()
    direction = str(globals().get("gap_day_direction", "") or "").upper()
    is_gap = bool(globals().get("gap_day_mode", False))
    if not is_gap:
        return "NORMAL"
    if direction == "GAP UP":
        return "ACTIVE" if sig == "CE" else "IGNORE"
    if direction == "GAP DOWN":
        return "ACTIVE" if sig == "PE" else "IGNORE"
    return "IGNORE"


def weighted_orb_component(signal, snapshot):
    mode = gap_directional_orb_mode(signal)
    sig = str(signal or "").upper()

    if mode == "IGNORE":
        # Opposite-side gap trades should not receive ORB marks. The ORB
        # weight is moved into VWAP + EMA by weighted_component_weights().
        if sig == "CE":
            return 0, "Gap-down CE: ORB ignored, VWAP/EMA/Supertrend decide"
        if sig == "PE":
            return 0, "Gap-up PE: ORB ignored, VWAP/EMA/Supertrend decide"
        return 0, "No signal"

    try:
        high_value = float(orb_high) if orb_high is not None else None
        low_value = float(orb_low) if orb_low is not None else None
    except Exception:
        high_value = None
        low_value = None

    close = snapshot.get("close", 0)
    atr_buffer = max(snapshot.get("atr", 0) * 0.05, 2)
    if high_value is None or low_value is None:
        return 8, "ORB not ready, using momentum score only"

    if sig == "CE":
        if close > high_value + atr_buffer:
            label = "Gap-up continuation" if mode == "ACTIVE" else "Breakout"
            return 20, f"{label} above ORB high {high_value:.2f}"
        if close > high_value:
            return 16, f"Marginal ORB high break {high_value:.2f}"
        if close >= high_value - max(snapshot.get("atr", 0) * 0.18, 6):
            return 9, "Near ORB high with momentum"
        return 0, "Below ORB high"

    if sig == "PE":
        if close < low_value - atr_buffer:
            label = "Gap-down continuation" if mode == "ACTIVE" else "Breakdown"
            return 20, f"{label} below ORB low {low_value:.2f}"
        if close < low_value:
            return 16, f"Marginal ORB low break {low_value:.2f}"
        if close <= low_value + max(snapshot.get("atr", 0) * 0.18, 6):
            return 9, "Near ORB low with momentum"
        return 0, "Above ORB low"

    return 0, "No signal"


