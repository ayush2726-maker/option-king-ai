    except Exception:
        try:
            ts = ts.tz_localize(None)
        except Exception:
            pass
    return ts.to_pydatetime().replace(tzinfo=None)


def option_candle_at_or_after(option_df, when_dt, max_delay_minutes=2):
    if option_df is None or option_df.empty:
        return None, None
    when_py = backtest_timestamp(when_dt)
    times = pd.to_datetime(option_df["dt"], errors="coerce")
    try:
        if getattr(times.dt, "tz", None) is not None:
            times = times.dt.tz_convert(ZoneInfo(MARKET_TIMEZONE)).dt.tz_localize(None)
    except Exception:
        try:
            times = times.dt.tz_localize(None)
        except Exception:
            pass
    times_py = times.apply(lambda item: backtest_timestamp(item) if not pd.isna(item) else None)
    rows = option_df[times_py >= when_py]
    if rows.empty:
        return None, None
    idx = int(rows.index[0])
    row = option_df.loc[idx]
    delay = (backtest_timestamp(row["dt"]) - when_py).total_seconds() / 60
    if delay > max_delay_minutes:
        return None, None
    return row, idx


