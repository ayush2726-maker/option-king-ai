def get_qty(premium, trade_type, lot_size):
    qty = _OKAI_EXPIRY_BASE_GET_QTY(premium, trade_type, lot_size)
    if not is_expiry_day() or qty <= 0:
        return qty
    try:
        premium = float(premium or 0)
        lot_size = int(lot_size or FAST_LOT_SIZE)
    except Exception:
        return 0
    if premium <= 0 or lot_size <= 0:
        return 0

    base_capital = max(float(capital or 0), float(paper_capital or 0))
    capital_cap_amount = base_capital * (expiry_capital_use_percent() / 100)
    capital_cap_qty = int(capital_cap_amount // (premium * lot_size)) * lot_size

    final_qty = min(qty, capital_cap_qty)
    reasons = []
    if final_qty < qty:
        reasons.append(f"capital-use cap {expiry_capital_use_percent():.0f}%")

    if premium < expiry_low_premium_cap_below():
        low_premium_qty = expiry_low_premium_qty_cap_lots() * lot_size
        if final_qty > low_premium_qty:
            final_qty = low_premium_qty
            reasons.append(f"low-premium cap {expiry_low_premium_qty_cap_lots()} lots")

    if loss_streak > 0:
        loss_cap_qty = int((qty * (expiry_after_loss_qty_percent() / 100)) // lot_size) * lot_size
        loss_cap_qty = max(lot_size, loss_cap_qty)
        if final_qty > loss_cap_qty:
            final_qty = loss_cap_qty
            reasons.append(f"after-loss size {expiry_after_loss_qty_percent():.0f}%")

    final_qty = max(0, (int(final_qty) // lot_size) * lot_size)
    if final_qty < lot_size:
        gui_log(
            f"Expiry qty blocked | Premium {premium:.2f} | Lot {lot_size} | "
            f"Capital cap {expiry_capital_use_percent():.0f}%"
        )
        return 0
    if reasons:
        gui_log(
            f"Expiry qty safety | Requested {qty} | Final {final_qty} | "
            f"Premium {premium:.2f} | " + " + ".join(reasons)
        )
    return final_qty


