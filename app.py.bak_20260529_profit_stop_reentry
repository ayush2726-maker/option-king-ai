    fake = int(decision.get("fake_breakout_probability", setup.get("fake_breakout_probability", 0)) or 0)
    regime = str(setup.get("market_regime", "UNKNOWN") or "UNKNOWN").upper()
    min_entry = int(weighted_min_entry_score())

    hard_block = ""
    if score < weighted_small_threshold():
        hard_block = f"Weighted score {score}/100 below no-trade floor {weighted_small_threshold():.0f}"
    elif score < min_entry:
        hard_block = f"Weighted score {score}/100 is watch-only; early entry starts at {min_entry}"
    elif confidence <= weighted_execute_confidence():
        hard_block = f"Confidence {confidence}% not above execution threshold {weighted_execute_confidence():.0f}%"
    elif fake > weighted_max_fake_breakout_probability():
        hard_block = f"Fake breakout probability {fake}% too high"
    elif weighted_is_sideways_regime(setup):
        hard_block = f"Market regime {regime} is sideways; no trade"
    elif regime == "EXPIRY_MANIPULATION" and (score < weighted_strong_threshold() or confidence < 88):
        hard_block = "Expiry manipulation risk requires strong score and 88% confidence"

    if hard_block:
        decision["take_trade"] = False
        decision["signal"] = "WAIT"
        decision["entry_type"] = "NONE"
        decision["reason"] = hard_block
    elif decision.get("take_trade"):
        decision["signal"] = setup_signal
        if score >= weighted_strong_threshold():
            decision["entry_type"] = "STRONG"
        elif score >= weighted_early_threshold():
            decision["entry_type"] = "EARLY"
        decision["reason"] = f"{source} quality filter passed | {decision.get('reason', fallback.get('reason', ''))}"
    return decision


