def core_bridge_scores_from_closed(df, price=None, orb_high_value=None, orb_low_value=None, gap_day=None):
    work = prepare_weighted_backtest_df(df)
    work = closed_indicator_df(work)
    if work is None or len(work) < 4:
        return None

    last = work.iloc[-1]
    c1 = work.iloc[-2]
    c2 = work.iloc[-1]
    close = float(price if price is not None else last.get("close", 0) or 0)
    vwap = float(last.get("VWAP", last.get("vwap", close)) or close)
    ema9 = float(last.get("EMA9", last.get("ema9", close)) or close)
    ema21 = float(last.get("EMA21", last.get("ema21", close)) or close)
    st_dir = str(last.get("SUPERTREND_DIR", last.get("supertrend_dir", "NEUTRAL")) or "NEUTRAL").upper()
    atr = float(recent_atr_points(work, 14) or 0)
    gap = bool(update_gap_day_mode(work) if gap_day is None else gap_day)

    oh = float(orb_high_value if orb_high_value is not None else (orb_high or 0) or 0)
    ol = float(orb_low_value if orb_low_value is not None else (orb_low or 0) or 0)
    ce_orb = bool((not gap) and oh and close > (oh + ORB_BREAK_BUFFER_POINTS) and float(c2.get("close", close) or close) > oh)
    pe_orb = bool((not gap) and ol and close < (ol - ORB_BREAK_BUFFER_POINTS) and float(c2.get("close", close) or close) < ol)

    ce_parts = {
        "vwap": close > vwap,
        "supertrend": st_dir == "UP",
        "ema": ema9 > ema21,
        "candle": bool(core_bridge_candle_score(c1, c2, "CE")),
        "orb": ce_orb,
    }
    pe_parts = {
        "vwap": close < vwap,
        "supertrend": st_dir == "DOWN",
        "ema": ema9 < ema21,
        "candle": bool(core_bridge_candle_score(c1, c2, "PE")),
        "orb": pe_orb,
    }
    active_keys = ["vwap", "supertrend", "ema", "candle"] if gap else ["vwap", "supertrend", "ema", "candle", "orb"]
    ce_score = sum(1 for key in active_keys if ce_parts.get(key))
    pe_score = sum(1 for key in active_keys if pe_parts.get(key))
    min_score = core_bridge_min_score(gap)

    return {
        "close": close,
        "vwap": vwap,
        "ema9": ema9,
        "ema21": ema21,
        "supertrend": st_dir,
        "atr": atr,
        "gap_day": gap,
        "score_total": len(active_keys),
        "min_score": min_score,
        "ce_score": ce_score,
        "pe_score": pe_score,
        "ce_parts": ce_parts,
        "pe_parts": pe_parts,
        "active_keys": active_keys,
    }


def core_bridge_best_signal(scores):
    if not scores:
        return None, "NONE", 0, ""
    ce_score = int(scores.get("ce_score", 0) or 0)
    pe_score = int(scores.get("pe_score", 0) or 0)
    min_score = int(scores.get("min_score", 4) or 4)
    if max(ce_score, pe_score) < min_score:
        return None, "NONE", max(ce_score, pe_score), f"Core score {max(ce_score, pe_score)}/{scores.get('score_total')} below {min_score}"
    if abs(ce_score - pe_score) <= 0:
        pass
    if ce_score == pe_score:
        return None, "NONE", ce_score, "CE/PE core score conflict; wait"
    signal = "CE" if ce_score > pe_score else "PE"
    score = ce_score if signal == "CE" else pe_score
    parts = scores.get("ce_parts" if signal == "CE" else "pe_parts", {})
    passed = [key.upper() for key in scores.get("active_keys", []) if parts.get(key)]
    reason = (
        f"Core bridge {signal}: {score}/{scores.get('score_total')} "
        f"({'+'.join(passed)})"
    )
    if scores.get("gap_day"):
        reason += " | Gap day ORB ignored"
    return signal, "FULL", score, reason


def core_bridge_weighted_quality_ok(signal, df, price):
    try:
        setup = compute_weighted_setup(signal, df, price)
        regime = str(setup.get("market_regime", "") or "").upper()
        if "SIDEWAYS" in regime or "CHOPPY" in regime or "RANGE" in regime:
            return False, f"Core bridge blocked: {regime}"
        fake = int(setup.get("fake_breakout_probability", 0) or 0)
        max_fake = int(_okai_config_float("core_bridge_max_fake_breakout", 42, 20, 70))
        if fake > max_fake:
            return False, f"Core bridge blocked: fake breakout {fake}%>{max_fake}%"
        return True, f"Weighted quality OK | score {setup.get('score', 0)}/100 | fake {fake}% | {regime}"
    except Exception as exc:
        return True, f"Weighted quality skipped: {str(exc)[:80]}"


