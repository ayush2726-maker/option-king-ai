    if direction == "UP" and snapshot.get("ema9", 0) >= snapshot.get("ema21", 0) and structure.get("bias") in {"UP", "NEUTRAL"}:
        label = "TRENDING_BULLISH"
    elif direction == "DOWN" and snapshot.get("ema9", 0) <= snapshot.get("ema21", 0) and structure.get("bias") in {"DOWN", "NEUTRAL"}:
        label = "TRENDING_BEARISH"
    elif volume_ratio < 0.72 and abs(snapshot.get("close", 0) - snapshot.get("vwap", 0)) <= max(snapshot.get("atr", 0) * 0.20, 4):
        label = "SIDEWAYS_LOW_VOLUME"
    elif "CHOPPY" in regime:
        label = "SIDEWAYS"

    expiry = weighted_expiry_manipulation(df, snapshot, {"regime": label})
    if expiry.get("active"):
        label = "EXPIRY_MANIPULATION"

    return {
        "regime": label,
        "direction": "UP" if label == "TRENDING_BULLISH" else "DOWN" if label == "TRENDING_BEARISH" else direction,
        "base_regime": base,
        "structure": structure,
        "atr": round(_w_float(snapshot.get("atr"), 0), 2),
        "atr_percent": round(atr_percent, 4),
        "volume_ratio": round(volume_ratio, 3),
        "expiry": expiry,
        "reason": f"{label} | base {regime} | volume {volume_ratio:.2f}x | ATR {atr_percent:.3f}%",
    }


def weighted_orb_component(signal, snapshot):
    try:
        high_value = float(orb_high) if orb_high is not None else None
        low_value = float(orb_low) if orb_low is not None else None
    except Exception:
        high_value = None
        low_value = None
    close = snapshot.get("close", 0)
    atr_buffer = max(snapshot.get("atr", 0) * 0.05, 2)
    if gap_day_mode and (high_value is None or low_value is None):
        return 12, "Gap day, ORB neutral"
    if high_value is None or low_value is None:
        return 8, "ORB not ready, using momentum score only"
    if signal == "CE":
        if close > high_value + atr_buffer:
            return 20, f"Breakout above ORB high {high_value:.2f}"
        if close > high_value:
            return 16, f"Marginal ORB high break {high_value:.2f}"
        if close >= high_value - max(snapshot.get("atr", 0) * 0.18, 6):
            return 9, "Near ORB high with momentum"
        return 0, "Below ORB high"
    if signal == "PE":
        if close < low_value - atr_buffer:
            return 20, f"Breakdown below ORB low {low_value:.2f}"
        if close < low_value:
            return 16, f"Marginal ORB low break {low_value:.2f}"
        if close <= low_value + max(snapshot.get("atr", 0) * 0.18, 6):
            return 9, "Near ORB low with momentum"
        return 0, "Above ORB low"
    return 0, "No signal"


def weighted_vwap_component(signal, snapshot):
    close = snapshot.get("close", 0)
    vwap = snapshot.get("vwap", close)
    atr = max(snapshot.get("atr", 0), 1)
    distance = close - vwap
    if signal == "CE":
        if distance > atr * 0.05:
            return 15, "Price above VWAP"
        if distance >= -atr * 0.12:
            return 8, "Price near VWAP, bullish early"
        return 0, "Price below VWAP"
    if signal == "PE":
        if distance < -atr * 0.05:
            return 15, "Price below VWAP"
        if distance <= atr * 0.12:
            return 8, "Price near VWAP, bearish early"
        return 0, "Price above VWAP"
    return 0, "No signal"


def weighted_ema_component(signal, snapshot):
    ema9 = snapshot.get("ema9", 0)
    ema21 = snapshot.get("ema21", 0)
    slope = snapshot.get("ema_slope", 0)
    if signal == "CE":
        if ema9 > ema21 and slope > 0:
            return 15, "EMA trend bullish"
        if slope > 0:
            return 8, "EMA slope bullish, crossover pending"
        return 0, "EMA not bullish"
    if signal == "PE":
        if ema9 < ema21 and slope < 0:
            return 15, "EMA trend bearish"
        if slope < 0:
            return 8, "EMA slope bearish, crossover pending"
        return 0, "EMA not bearish"
    return 0, "No signal"


def weighted_volume_component(snapshot):
    volume = snapshot.get("volume", 0)
    avg_volume = snapshot.get("avg_volume", 0)
    if avg_volume <= 0:
        return 8, "Volume average unavailable"
    ratio = volume / avg_volume
    if ratio >= 1.25:
        return 15, f"Volume spike {ratio:.2f}x"
    if ratio >= 0.90:
        return 9, f"Volume acceptable {ratio:.2f}x"
    return 0, f"Low volume {ratio:.2f}x"


def weighted_candle_component(signal, snapshot):
    body_ratio = snapshot.get("body_ratio", 0)
    close_pos = snapshot.get("close_pos", 0.5)
    close = snapshot.get("close", 0)
    open_ = snapshot.get("open", close)
    if signal == "CE":
        if close > open_ and body_ratio >= 0.35 and close_pos >= 0.62:
            return 10, "Strong bullish candle close"
        if close >= open_ and close_pos >= 0.52:
            return 5, "Bullish candle forming"
        return 0, "Candle close weak for call"
    if signal == "PE":
        if close < open_ and body_ratio >= 0.35 and close_pos <= 0.38:
            return 10, "Strong bearish candle close"
        if close <= open_ and close_pos <= 0.48:
            return 5, "Bearish candle forming"
        return 0, "Candle close weak for put"
    return 0, "No signal"


def weighted_fake_breakout_probability(setup):
    snapshot = setup.get("snapshot") or {}
    regime = setup.get("regime") or {}
    components = setup.get("components") or {}
    score = int(setup.get("score", 0) or 0)
    fake = 24
    if score >= 80:
        fake -= 8
    elif score < 65:
        fake += 10
    if components.get("orb_breakout", {}).get("score", 0) < 12:
        fake += 8
    if components.get("volume_spike", {}).get("score", 0) <= 3:
        fake += 12
    if components.get("vwap_alignment", {}).get("score", 0) == 0:
        fake += 7
    if max(snapshot.get("upper_wick_ratio", 0), snapshot.get("lower_wick_ratio", 0)) >= 0.50:
        fake += 10
    if str(regime.get("regime", "")).upper() in {"SIDEWAYS", "SIDEWAYS_LOW_VOLUME", "EXPIRY_MANIPULATION"}:
        fake += 12
    if str(regime.get("regime", "")).upper() == "HIGH_VOLATILITY":
        fake += 6
    if regime.get("expiry", {}).get("active"):
        fake += 14
    if setup.get("signal") == "CE" and snapshot.get("upper_wick_ratio", 0) >= 0.42:
        fake += 5
    if setup.get("signal") == "PE" and snapshot.get("lower_wick_ratio", 0) >= 0.42:
        fake += 5
    return int(_w_clamp(fake, 3, 92))


def compute_weighted_setup(signal, df, price):
    snapshot = weighted_indicator_snapshot(df, price)
    if not snapshot.get("ready"):
        return {
            "signal": signal,
            "score": 0,
            "confidence": 0,
            "entry_type": "NONE",
            "trade_type": "NONE",
            "take_trade": False,
            "reason": snapshot.get("reason", "Data wait"),
            "components": {},
            "snapshot": snapshot,
        }

    regime = weighted_regime_engine(df, snapshot)
    mtf = multi_timeframe_trend(df)
    structure = weighted_market_structure(df, signal)
    orb_score, orb_reason = weighted_orb_component(signal, snapshot)
    vwap_score, vwap_reason = weighted_vwap_component(signal, snapshot)
    ema_score, ema_reason = weighted_ema_component(signal, snapshot)
    volume_score, volume_reason = weighted_volume_component(snapshot)
    candle_score, candle_reason = weighted_candle_component(signal, snapshot)
    chain = weighted_option_chain_proxy(signal)
    oi = weighted_oi_buildup_proxy(signal)

    components = {
        "orb_breakout": {"score": int(orb_score), "weight": 20, "reason": orb_reason},
        "vwap_alignment": {"score": int(vwap_score), "weight": 15, "reason": vwap_reason},
        "ema_alignment": {"score": int(ema_score), "weight": 15, "reason": ema_reason},
        "volume_spike": {"score": int(volume_score), "weight": 15, "reason": volume_reason},
        "strong_candle_close": {"score": int(candle_score), "weight": 10, "reason": candle_reason},
        "option_chain_support": {"score": int(chain.get("score", 0)), "weight": 15, "reason": chain.get("reason", "")},
        "oi_buildup": {"score": int(oi.get("score", 0)), "weight": 10, "reason": oi.get("reason", "")},
    }
    raw_score = sum(item["score"] for item in components.values())
    signal_dir = _w_direction(signal)
    confidence = raw_score
    modifiers = []

    if regime.get("direction") == signal_dir:
        confidence += 5
        modifiers.append("regime aligned")
    elif regime.get("direction") not in {"NEUTRAL", signal_dir}:
        confidence -= 8
        modifiers.append("regime opposite")

    if mtf.get("bias") == signal_dir:
        confidence += min(6, 2 + int(mtf.get("score", 0) or 0) * 2)
        modifiers.append("MTF aligned")
    elif mtf.get("bias") not in {"NEUTRAL", signal_dir}:
        confidence -= 7
        modifiers.append("MTF opposite")

    if structure.get("bias") == signal_dir:
        confidence += 4
        modifiers.append("structure aligned")
    elif structure.get("bias") not in {"NEUTRAL", signal_dir}:
        confidence -= 5
        modifiers.append("structure opposite")

    expiry = regime.get("expiry") or {}
    if expiry.get("score_penalty"):
        confidence -= float(expiry.get("score_penalty", 0))
        modifiers.append(expiry.get("reason", "expiry risk"))

    learning = learning_profile(signal)
    confidence += int(learning.get("adjustment", 0) or 0)
    if learning.get("summary"):
        modifiers.append(str(learning.get("summary")))

    confidence = int(_w_clamp(round(confidence), 0, 99))
    score = int(_w_clamp(raw_score, 0, 100))
    entry_type = "NONE"
    trade_type = "NONE"
    size_factor = 0.0
    if score >= weighted_strong_threshold():
        entry_type = "STRONG"
        trade_type = "FULL"
        size_factor = 1.0
    elif score >= weighted_early_threshold():
        entry_type = "EARLY"
        trade_type = "HALF"
        size_factor = weighted_early_size_factor()
    elif score >= weighted_small_threshold():
        entry_type = "SMALL"
        trade_type = "HALF"
        size_factor = weighted_small_size_factor()

    setup = {
        "signal": signal,
        "signal_name": _w_signal_name(signal),
        "score": score,
        "raw_score": int(raw_score),
        "confidence": confidence,
        "entry_type": entry_type,
        "trade_type": trade_type,
        "size_factor": size_factor,
        "components": components,
        "component_total": 100,
        "snapshot": snapshot,
        "market_regime": regime.get("regime"),
        "regime": regime,
        "multi_timeframe": mtf,
        "market_structure": structure,
        "option_chain": chain,
        "oi_buildup": oi,
        "learning": learning,
        "modifiers": modifiers,
        "take_trade": False,
    }
    setup["fake_breakout_probability"] = weighted_fake_breakout_probability(setup)
    setup["risk"] = weighted_risk_level(setup)
    top_reasons = [
        f"{name}: {item.get('score')}/{item.get('weight')} {item.get('reason')}"
        for name, item in components.items()
        if int(item.get("score", 0) or 0) > 0
    ]
    setup["reason"] = " | ".join(top_reasons[:4]) if top_reasons else "No weighted edge yet"
    return setup


def weighted_risk_level(setup):
    fake = int(setup.get("fake_breakout_probability", 0) or 0)
    regime = str(setup.get("market_regime", "")).upper()
    score = int(setup.get("score", 0) or 0)
    if fake >= 55 or regime in {"EXPIRY_MANIPULATION", "SIDEWAYS_LOW_VOLUME"}:
        return "HIGH"
    if fake >= 35 or score < 80 or regime == "HIGH_VOLATILITY":
        return "MEDIUM"
    return "LOW"


def choose_weighted_candidate(df, price):
    ce = compute_weighted_setup("CE", df, price)
    pe = compute_weighted_setup("PE", df, price)
    candidates = sorted([ce, pe], key=lambda item: (int(item.get("score", 0) or 0), int(item.get("confidence", 0) or 0)), reverse=True)
    best = candidates[0]
    other = candidates[1]
    if int(best.get("score", 0) or 0) < weighted_small_threshold():
        best["take_trade"] = False
        best["reason"] = f"Weighted score {best.get('score', 0)}/100 below small-entry threshold"
        best["other_candidate"] = other
        return best
    if int(other.get("score", 0) or 0) >= weighted_small_threshold() and abs(int(best.get("score", 0)) - int(other.get("score", 0))) < 6:
        best["confidence"] = max(0, int(best.get("confidence", 0)) - 5)
        best["modifiers"] = list(best.get("modifiers") or []) + ["CALL/PUT conflict"]
    best["other_candidate"] = other
    return best


def local_gemini_decision(setup):
    confidence = int(setup.get("confidence", 0) or 0)
    score = int(setup.get("score", 0) or 0)
    fake = int(setup.get("fake_breakout_probability", 0) or 0)
    regime = str(setup.get("market_regime", "UNKNOWN") or "UNKNOWN")
    entry_type = str(setup.get("entry_type", "NONE") or "NONE")
    signal_name = setup.get("signal_name", "WAIT")
    reason = setup.get("reason", "Weighted setup evaluation")
    take_trade = (
        signal_name in {"BUY_CALL", "BUY_PUT"}
        and score >= weighted_small_threshold()
        and confidence > weighted_execute_confidence()
        and fake <= weighted_max_fake_breakout_probability()
        and not (regime == "SIDEWAYS_LOW_VOLUME" and score < weighted_strong_threshold())
        and not (regime == "EXPIRY_MANIPULATION" and confidence < 88)
    )
    if entry_type == "SMALL" and confidence <= weighted_execute_confidence():
        reason = "Small setup found, waiting for confidence above execution threshold"
    elif fake > weighted_max_fake_breakout_probability():
        reason = f"Fake breakout probability {fake}% too high"
    elif regime == "SIDEWAYS_LOW_VOLUME" and score < weighted_strong_threshold():
        reason = "Avoiding low-volume sideways market"
    elif take_trade:
        reason = f"{entry_type} {signal_name} setup | {reason}"
    return {
        "take_trade": bool(take_trade),
        "signal": signal_name if take_trade else "WAIT",
        "confidence": int(confidence),
        "entry_type": entry_type,
        "risk": weighted_risk_level(setup),
        "fake_breakout_probability": int(fake),
        "reason": reason,
    }


def _normalize_gemini_json(data, fallback):
    if not isinstance(data, dict):
        return fallback
    signal = str(data.get("signal", fallback.get("signal", "WAIT")) or "WAIT").upper()
    if signal not in {"BUY_CALL", "BUY_PUT", "WAIT"}:
        signal = fallback.get("signal", "WAIT")
    entry_type = str(data.get("entry_type", fallback.get("entry_type", "NONE")) or "NONE").upper()
    if entry_type not in {"STRONG", "EARLY", "SMALL", "NONE"}:
        entry_type = fallback.get("entry_type", "NONE")
    risk = str(data.get("risk", fallback.get("risk", "MEDIUM")) or "MEDIUM").upper()
    if risk not in {"LOW", "MEDIUM", "HIGH"}:
        risk = fallback.get("risk", "MEDIUM")
    return {
        "take_trade": bool(data.get("take_trade", fallback.get("take_trade", False))),
        "signal": signal,
        "confidence": int(_w_clamp(data.get("confidence", fallback.get("confidence", 0)), 0, 100)),
        "entry_type": entry_type,
        "risk": risk,
        "fake_breakout_probability": int(_w_clamp(data.get("fake_breakout_probability", fallback.get("fake_breakout_probability", 0)), 0, 100)),
        "reason": str(data.get("reason", fallback.get("reason", "")) or fallback.get("reason", ""))[:500],
    }


def gemini_decision_layer(setup):
    fallback = local_gemini_decision(setup)
    if not gemini_decision_enabled():
        fallback["reason"] = "Gemini layer OFF, local weighted decision used: " + fallback.get("reason", "")
        return fallback
    if not external_gemini_enabled():
        fallback["model"] = "local-gemini-rules"
        return fallback
    key = str(config.get("gemini_api_key") or os.environ.get("GEMINI_API_KEY") or "").strip()
    if not key:
        fallback["model"] = "local-gemini-rules"
        fallback["reason"] = "Gemini key missing, local decision used: " + fallback.get("reason", "")
        return fallback
    model = str(config.get("gemini_model", "gemini-3.5-flash") or "gemini-3.5-flash")
    payload = json_safe({
        "instruction": (
            "Evaluate only current NIFTY options setup quality and probability. "
            "Do not predict future candles. Return strict JSON with keys: "
            "take_trade, signal, confidence, entry_type, risk, fake_breakout_probability, reason."
        ),
        "setup": setup,
        "execution_rule": {
            "execute_if_confidence_gt": weighted_execute_confidence(),
            "max_fake_breakout_probability": weighted_max_fake_breakout_probability(),
        },
    })
    try:
        url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={key}"
        body = {
            "contents": [{"parts": [{"text": json.dumps(payload, ensure_ascii=False)[:9000]}]}],
            "generationConfig": {
                "temperature": 0.0,
                "response_mime_type": "application/json",
                "maxOutputTokens": 300,
            },
        }
        res = requests.post(url, json=body, timeout=7)
        res.raise_for_status()
        text = (((res.json().get("candidates") or [{}])[0].get("content") or {}).get("parts") or [{}])[0].get("text", "")
        decision = _normalize_gemini_json(json.loads(text), fallback)
        decision["model"] = model
        return decision
    except Exception as exc:
        fallback["model"] = "local-gemini-rules"
        fallback["reason"] = f"Gemini fallback: {exc} | {fallback.get('reason', '')}"
        return fallback


