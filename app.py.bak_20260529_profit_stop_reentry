            "time": trade.get("time", ""),
            "event": "BUY",
            "side": "PURCHASE",
            "price": entry,
            "turnover": entry * qty,
            "charges": buy_charges,
            "gross_pnl": 0.0,
            "net_pnl": -buy_charges,
