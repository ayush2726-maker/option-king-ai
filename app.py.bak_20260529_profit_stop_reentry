def websocket_subscription_tokens():
    configured = config.get("websocket_subscriptions")
    groups = {}
    if isinstance(configured, list) and configured:
        for item in configured:
            if not isinstance(item, dict):
                continue
            exchange_type = int(item.get("exchangeType") or websocket_exchange_type(item.get("exchange")))
            tokens = [str(token) for token in item.get("tokens", []) if str(token)]
            if tokens:
                groups.setdefault(exchange_type, set()).update(tokens)
    else:
        groups.setdefault(websocket_exchange_type("NSE"), set()).add(str(NIFTY_TOKEN))
    if position is not None:
        option = position.get("option") or {}
        token = str(option.get("token") or "")
        if token:
            groups.setdefault(websocket_exchange_type(option.get("exchange", "NFO")), set()).add(token)
    return [{"exchangeType": int(exchange_type), "tokens": sorted(tokens)} for exchange_type, tokens in groups.items() if tokens]


def start_websocket():
    global safe_ws_client, safe_ws_thread
    if not _safe_config_bool("websocket_feed_enabled", False):
        safe_websocket_state["enabled"] = False
        safe_websocket_state["status"] = "not_configured"
        return False
    if safe_ws_thread is not None and safe_ws_thread.is_alive():
        safe_websocket_state["enabled"] = True
        safe_websocket_state["status"] = safe_websocket_state.get("status") or "connecting"
        return True
    try:
        from SmartApi.smartWebSocketV2 import SmartWebSocketV2
        angel_login()
        auth_token = getattr(obj, "access_token", None)
        feed_token = getattr(obj, "feed_token", None) or obj.getfeedToken()
        if not auth_token or not feed_token:
            raise RuntimeError("Angel auth/feed token unavailable for websocket")
        token_list = websocket_subscription_tokens()
        if not token_list:
            raise RuntimeError("No websocket tokens configured")
        safe_websocket_state.update({
            "enabled": True,
            "connected": False,
            "status": "connecting",
            "last_error": "",
            "token_count": sum(len(item.get("tokens", [])) for item in token_list),
        })
        client = SmartWebSocketV2(
            auth_token,
            str(config.get("api_key") or ""),
            str(config.get("client_id") or ""),
            feed_token,
            max_retry_attempt=_safe_config_int("websocket_sdk_max_retries", 1, 0, 5),
            retry_strategy=0,
            retry_delay=_safe_config_int("websocket_sdk_retry_delay", 5, 1, 60),
            retry_multiplier=2,
            retry_duration=_safe_config_int("websocket_sdk_retry_duration_minutes", 2, 1, 30),
        )

        def _on_open(_wsapp):
            mark_websocket_tick({"event": "open"})
            try:
                client.subscribe(
                    f"OKAI{int(_safe_now_ts()) % 100000}",
                    _safe_config_int("websocket_mode", 1, 1, 3),
                    token_list,
                )
                safe_append_event("WEBSOCKET_SUBSCRIBED", {"tokens": token_list})
            except Exception as exc:
                mark_websocket_disconnect(f"subscribe failed: {exc}")

        def _on_data(_wsapp, data):
            mark_websocket_tick(data if isinstance(data, dict) else {"raw": str(data)[:200]})

        def _on_error(_wsapp, error):
            mark_websocket_disconnect(f"error: {error}")

        def _on_close(_wsapp):
            mark_websocket_disconnect("closed")

        client.on_open = _on_open
        client.on_data = _on_data
        client.on_error = _on_error
        client.on_close = _on_close
        safe_ws_client = client

        def _run():
            try:
                client.connect()
            except Exception as exc:
                mark_websocket_disconnect(f"connect failed: {exc}")

        safe_ws_thread = threading.Thread(target=_run, daemon=True, name="okai-smartapi-websocket")
        safe_ws_thread.start()
        safe_append_event("WEBSOCKET_START", {"tokens": token_list})
        return True
    except Exception as exc:
        safe_websocket_state.update({
            "enabled": True,
            "connected": False,
            "status": "start_failed",
            "last_error": str(exc)[:220],
        })
        safe_append_event("WEBSOCKET_START_FAILED", {"error": str(exc)})
        return False


