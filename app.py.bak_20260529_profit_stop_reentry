        return
    safe_last_log_rotate_day = today
    try:
        ensure_dirs()
        keep_days = _safe_config_int("safe_log_keep_days", 7, 1, 60)
        cutoff = market_now().date() - dt.timedelta(days=keep_days)
        for filename in os.listdir(TRADE_DIR):
            if not (
                filename.startswith(MOBILE_SAFE_EVENT_PREFIX)
                or filename.startswith(MOBILE_RUNTIME_LOG_PREFIX)
            ):
                continue
            path = os.path.join(TRADE_DIR, filename)
            if not os.path.isfile(path) or filename.endswith(".gz"):
                continue
            try:
                mtime = dt.datetime.fromtimestamp(os.path.getmtime(path)).date()
            except Exception:
                mtime = market_now().date()
            if mtime >= market_now().date():
                continue
            gz_path = path + ".gz"
            if not os.path.exists(gz_path):
                with open(path, "rb") as src, gzip.open(gz_path, "wb", compresslevel=6) as dst:
                    shutil.copyfileobj(src, dst)
            os.remove(path)
        for filename in os.listdir(TRADE_DIR):
            if not filename.endswith(".gz"):
                continue
            path = os.path.join(TRADE_DIR, filename)
            try:
                mtime = dt.datetime.fromtimestamp(os.path.getmtime(path)).date()
            except Exception:
                continue
            if mtime < cutoff:
                os.remove(path)
    except Exception as exc:
        safe_runtime["last_safe_error"] = f"log_rotate: {exc}"


