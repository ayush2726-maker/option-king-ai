            json.dump(_okai_df_to_candle_rows(df), file)
        gui_log(f"Spot candle cache saved: {os.path.basename(cache_path)}")
    except Exception as exc:
        gui_log(f"Spot candle cache save skipped: {str(exc)[:120]}")
    return df


def _okai_saved_trade_rows_for_day(day):
    path = os.path.join(TRADE_DIR, f"closed_trades_{day.strftime('%Y%m%d')}.csv")
    if not os.path.exists(path):
        return []
    rows = []
    with open(path, "r", encoding="utf-8", newline="") as file:
        for row in csv.DictReader(file):
            rows.append(normalize_closed_trade_row(row))
    return rows


def _okai_stored_trade_report(payload, mode, start_capital):
    start_day, end_day = parse_backtest_month(payload.get("month") or payload.get("date"))
    if str(mode or "").upper() in STORED_REPLAY_MODES and payload.get("date") and not payload.get("month"):
        start_day = parse_backtest_day(payload.get("date"))
        end_day = start_day

    running_capital = float(start_capital)
    all_rows = []
    day_lines = []
    skipped = []
    for day in backtest_market_days(start_day, end_day):
        rows = _okai_saved_trade_rows_for_day(day)
        if not rows:
            skipped.append(f"{day.strftime('%Y-%m-%d')} | no saved closed_trades file")
            continue
        pnl = sum(bt_float(row.get("pnl", row.get("net_pnl", 0)), 0) for row in rows)
        charges = sum(bt_float(row.get("charges", row.get("total_charges", 0)), 0) for row in rows)
        running_capital += pnl
        all_rows.extend(rows)
        day_lines.append(f"{day.strftime('%Y-%m-%d')} | Trades {len(rows)} | Net P&L {pnl:.2f} | Charges {charges:.2f} | Final {running_capital:.2f}")

    wins = sum(1 for row in all_rows if bt_float(row.get("pnl", row.get("net_pnl", 0)), 0) > 0)
    losses = sum(1 for row in all_rows if bt_float(row.get("pnl", row.get("net_pnl", 0)), 0) <= 0)
    total_pnl = running_capital - float(start_capital)
    ret = (total_pnl / float(start_capital) * 100) if float(start_capital) else 0.0
    win_rate = (wins / len(all_rows) * 100) if all_rows else 0.0

    lines = [
        "SAVED TRADE DATA REPORT",
        "Mode: STORED DATA",
        "Source: phone saved closed_trades CSV files",
        "Note: this is actual saved paper-trade replay/report, not a fresh strategy simulation.",
        f"From: {start_day.strftime('%Y-%m-%d')} To: {end_day.strftime('%Y-%m-%d')}",
        f"Start Capital: {float(start_capital):.2f}",
        f"Final Capital: {running_capital:.2f}",
        f"Net P&L: {total_pnl:.2f}",
        f"Return: {ret:.2f}%",
        f"Trades: {len(all_rows)}",
        f"Wins: {wins}",
        f"Losses: {losses}",
        f"Win Rate: {win_rate:.2f}%",
    ]
    if skipped:
        lines += ["", "SKIPPED"] + skipped[:20]
    if day_lines:
        lines += ["", "DAY SUMMARY"] + day_lines
    if all_rows:
        lines += ["", "LAST TRADES"]
        for row in all_rows[-15:]:
            lines.append(
                f"{row.get('date','')} {row.get('time','')} | {row.get('signal','')} | "
                f"{row.get('symbol','')} | Qty {row.get('qty','')} | P&L {bt_float(row.get('pnl', row.get('net_pnl', 0)), 0):.2f} | "
                f"{row.get('reason','')}"
            )
    else:
        lines += ["", "No saved closed trades found for this range."]
    summary = f"SAVED DATA | Trades {len(all_rows)} | P&L {total_pnl:.2f} | Return {ret:.2f}%"
    return summary, "\n".join(lines)


def _okai_fast_estimate_signal(df, index, orb_high_value, orb_low_value, gap_day=False):
    ce_score, pe_score = backtest_score(df, index, orb_high_value, orb_low_value, gap_day)
    row = df.iloc[index]
    now_clock = row.get("clock")
    if now_clock and now_clock < TRADE_START:
        return None, "NONE", max(ce_score, pe_score)
    if ce_score >= 4 and ce_score >= pe_score:
        return "CE", "FULL", ce_score
    if pe_score >= 4 and pe_score > ce_score:
        return "PE", "FULL", pe_score
    return None, "NONE", max(ce_score, pe_score)


def run_mobile_backtest(payload=None):
    payload = payload or {}
    mode = str(payload.get("mode", "FAST") or "FAST").upper()
    start_capital = float(payload.get("capital") or paper_capital or capital)
    if mode in STORED_REPLAY_MODES:
        return _okai_stored_trade_report(payload, mode, start_capital)

    # FAST is a quick local estimate. Keep it lightweight so the phone does not
    # spend minutes recomputing the weighted AI stack candle-by-candle.
    if mode in {"FAST", "ESTIMATE", "QUICK"}:
        original = globals().get("backtest_signal")
        try:
            globals()["backtest_signal"] = _okai_fast_estimate_signal
            return _OKAI_STORED_BASE_RUN_MOBILE_BACKTEST(payload)
        finally:
            globals()["backtest_signal"] = original

    return _OKAI_STORED_BASE_RUN_MOBILE_BACKTEST(payload)


# ===== OPTION KING AI PATCH: LOCAL LEARNING RISK FILTER =====
# Version: 2026.05.28-local-learning-risk-1

SERVER_VERSION = "2026.05.28-local-learning-risk-1"

_OKAI_LOCAL_LEARNING_BASE_BUILD_TRADE_QUALITY = _okai_build_trade_quality
_OKAI_LOCAL_LEARNING_BASE_STATUS_PAYLOAD = status_payload
_OKAI_LOCAL_LEARNING_BASE_BUILD_SETTINGS_TEXT = build_settings_text

local_learning_runtime = {
    "last_refresh": 0.0,
    "summary": "Local learning waiting for trade history",
    "rules": {},
    "sample": 0,
}


def _okai_learning_trade_pnl(row):
    return _okai_quality_float(row.get("pnl", row.get("net_pnl", 0)), 0.0)


def _okai_learning_trade_hour(row):
    try:
        return int(str(row.get("time", "00:00") or "00:00")[:2])
    except Exception:
        return -1


def _okai_learning_trade_date(row):
    return str(row.get("date", "") or "")


def _okai_learning_reason(row):
    return str(row.get("reason", "") or "").upper()


def _okai_learning_bucket_key(signal, hour):
    return f"{str(signal or '').upper()}_{int(hour):02d}"


def _okai_learning_win_rate(rows):
    if not rows:
        return 0.0
    wins = sum(1 for row in rows if _okai_learning_trade_pnl(row) > 0)
    return wins / len(rows)


def _okai_learning_net(rows):
    return sum(_okai_learning_trade_pnl(row) for row in rows)


def _okai_rebuild_local_learning(force=False):
    now_ts = time.time()
    if not force and now_ts - float(local_learning_runtime.get("last_refresh", 0) or 0) < 45:
        return local_learning_runtime

    rows = list(trade_history[-120:])
    today = market_day_text()
    rules = {}
    summaries = []

    for signal in ("CE", "PE"):
        signal_rows = [row for row in rows if str(row.get("signal", "")).upper() == signal]
        if len(signal_rows) >= 4:
            wr = _okai_learning_win_rate(signal_rows)
            net = _okai_learning_net(signal_rows)
            rules[f"{signal}_overall"] = {"sample": len(signal_rows), "win_rate": round(wr, 3), "net": round(net, 2)}
            if wr < 0.40 and net < 0:
                summaries.append(f"{signal} caution overall WR {wr * 100:.0f}%")

        for hour in range(9, 16):
            bucket = [
                row for row in signal_rows
                if abs(_okai_learning_trade_hour(row) - hour) <= 1
            ]
            if len(bucket) < 3:
                continue
            wr = _okai_learning_win_rate(bucket)
            net = _okai_learning_net(bucket)
            early_fails = sum(1 for row in bucket if "EARLY EXIT" in _okai_learning_reason(row) or "PREMIUM FAILED" in _okai_learning_reason(row))
            reverse_fails = sum(1 for row in bucket if "REVERSAL" in _okai_learning_reason(row))
            rules[_okai_learning_bucket_key(signal, hour)] = {
                "sample": len(bucket),
                "win_rate": round(wr, 3),
                "net": round(net, 2),
                "early_fails": early_fails,
                "reverse_fails": reverse_fails,
            }

        today_rows = [row for row in signal_rows if _okai_learning_trade_date(row) == today]
        today_losses = [row for row in today_rows if _okai_learning_trade_pnl(row) <= 0]
        today_early_fails = [
            row for row in today_losses
            if "EARLY EXIT" in _okai_learning_reason(row) or "PREMIUM FAILED" in _okai_learning_reason(row)
        ]
        if today_losses:
            rules[f"{signal}_today"] = {
                "sample": len(today_rows),
                "losses": len(today_losses),
                "early_fails": len(today_early_fails),
                "net": round(_okai_learning_net(today_rows), 2),
            }

    local_learning_runtime.update({
        "last_refresh": now_ts,
        "rules": rules,
        "sample": len(rows),
        "summary": "; ".join(summaries[:4]) if summaries else f"Local learning active | samples {len(rows)}",
    })
    return local_learning_runtime


def _okai_local_learning_decision(signal, quality):
    if not _safe_config_bool("local_learning_filter_enabled", True):
        return {"enabled": False, "action": "OFF", "summary": "Local learning OFF", "blocks": [], "score_penalty": 0, "fake_penalty": 0}

    profile = _okai_rebuild_local_learning()
    signal = str(signal or "").upper()
    now = market_now()
    hour = now.hour
    rules = profile.get("rules") or {}
    bucket = rules.get(_okai_learning_bucket_key(signal, hour), {})
    today = rules.get(f"{signal}_today", {})
    overall = rules.get(f"{signal}_overall", {})
    blocks = []
    notes = []
    score_penalty = 0
    fake_penalty = 0

    if bucket:
        wr = float(bucket.get("win_rate", 0) or 0)
        net = float(bucket.get("net", 0) or 0)
        sample = int(bucket.get("sample", 0) or 0)
        early_fails = int(bucket.get("early_fails", 0) or 0)
        reverse_fails = int(bucket.get("reverse_fails", 0) or 0)
        notes.append(f"{signal} {hour}:00 bucket WR {wr * 100:.0f}%/{sample}")
        if sample >= 4 and wr < 0.38 and net < 0:
            blocks.append(f"local learning blocked {signal}: poor same-time WR {wr * 100:.0f}%")
        elif sample >= 3 and wr < 0.45 and net < 0:
            score_penalty -= 8
            fake_penalty += 8
        if early_fails >= 2:
            score_penalty -= 5
            fake_penalty += 5
            premium_move = _okai_quality_float(quality.get("premium_move_percent"), 0)
            premium_ext = _okai_quality_float(quality.get("premium_extension_percent"), 0)
            if premium_move < 0.20:
                blocks.append(f"local learning blocked {signal}: premium momentum weak after repeated premium-fail losses")
            if premium_ext > 8.0:
                blocks.append(f"local learning blocked {signal}: premium stretched after repeated premium-fail losses")
        if reverse_fails >= 2:
            score_penalty -= 4
            fake_penalty += 4

    if today:
        losses = int(today.get("losses", 0) or 0)
        early_fails = int(today.get("early_fails", 0) or 0)
        net = float(today.get("net", 0) or 0)
        if losses >= 2 and net < 0:
            score_penalty -= 10
            fake_penalty += 10
            notes.append(f"today {signal} losses {losses}")
        if early_fails >= 2:
            blocks.append(f"local learning blocked {signal}: today repeated premium-fail losses")

    if overall:
        wr = float(overall.get("win_rate", 0) or 0)
        net = float(overall.get("net", 0) or 0)
        sample = int(overall.get("sample", 0) or 0)
        if sample >= 8 and wr < 0.42 and net < 0:
            score_penalty -= 4
            fake_penalty += 4
        elif sample >= 8 and wr > 0.62 and net > 0:
            score_penalty += 2
            notes.append(f"{signal} learning support WR {wr * 100:.0f}%")

    if hour >= 14:
        # Late option buying becomes fragile near end of day, especially after
        # prior premium-fail exits. Require stronger evidence in that zone.
        score_penalty -= 5
        fake_penalty += 5
        notes.append("late-session caution")

    adjusted_score = _okai_quality_int(quality.get("score"), 0) + score_penalty
    adjusted_fake = _okai_quality_int(quality.get("fake_breakout_probability"), 0) + fake_penalty
    min_a_score = _okai_config_float("trade_quality_min_a_score", 70, 1, 100)
    max_fake_a = _okai_config_float("trade_quality_max_fake_a", 45, 5, 80)
    if not blocks:
        if adjusted_score < min_a_score:
            blocks.append(f"local learning score {adjusted_score}<{min_a_score:.0f}")
        if adjusted_fake > max_fake_a:
            blocks.append(f"local learning fake risk {adjusted_fake}%>{max_fake_a:.0f}%")

    return {
        "enabled": True,
        "action": "BLOCK" if blocks else "PASS",
        "summary": "; ".join(notes[:4]) if notes else profile.get("summary", "Local learning active"),
        "blocks": list(dict.fromkeys(blocks))[:5],
        "score_penalty": score_penalty,
        "fake_penalty": fake_penalty,
        "adjusted_score": adjusted_score,
        "adjusted_fake_breakout_probability": adjusted_fake,
        "sample": profile.get("sample", 0),
    }


def _okai_build_trade_quality(signal, premium=None, option=None, df=None, price=None, require_premium=True, backtest=False):
    approved, quality = _OKAI_LOCAL_LEARNING_BASE_BUILD_TRADE_QUALITY(signal, premium, option, df, price, require_premium, backtest)
    if backtest:
        return approved, quality
    learning = _okai_local_learning_decision(signal, quality)
    quality["local_learning"] = learning
    if learning.get("enabled") and learning.get("blocks"):
        quality["blocks"] = list(dict.fromkeys(list(quality.get("blocks") or []) + list(learning.get("blocks") or [])))[:8]
        quality["grade"] = "C"
        approved = False
    elif learning.get("enabled"):
        quality["score"] = learning.get("adjusted_score", quality.get("score"))
        quality["fake_breakout_probability"] = learning.get("adjusted_fake_breakout_probability", quality.get("fake_breakout_probability"))
    return approved, quality


