def should_skip_backup_file(path):
    normalized = path.replace("\\", "/")
    name = os.path.basename(path)
    return (
        "/__pycache__/" in normalized
        or name.endswith((".pyc", ".pyo"))
        or normalized.startswith(BACKUP_DIR.replace("\\", "/") + "/")
    )


def create_cloud_bot_backup(reason="manual"):
    ensure_dirs()
    stamp = market_now().strftime("%Y%m%d_%H%M%S")
    backup_name = f"OptionKingAI_cloud_bot_backup_{stamp}.zip"
    backup_path = os.path.join(BACKUP_DIR, backup_name)
    with zipfile.ZipFile(backup_path, "w", compression=zipfile.ZIP_DEFLATED, compresslevel=6) as archive:
        for root, dirs, files in os.walk(APP_DIR):
            dirs[:] = [item for item in dirs if item != "__pycache__"]
            for filename in files:
                file_path = os.path.join(root, filename)
                if should_skip_backup_file(file_path):
                    continue
                arcname = os.path.relpath(file_path, APP_DIR)
                archive.write(file_path, arcname)
        meta = {
            "created_at": market_now().isoformat(timespec="seconds"),
            "reason": reason,
            "server_version": SERVER_VERSION,
            "capital": capital,
            "daily_pnl": daily_pnl,
            "trade_count": len(trade_history),
        }
        archive.writestr("BACKUP_INFO.json", json.dumps(meta, indent=2))
    return backup_path


def upload_backup_to_google_drive(backup_path):
    remote = google_drive_backup_remote()
    if not remote:
        return False, "Google Drive remote is empty"
    rclone_path = shutil.which("rclone")
    if not rclone_path:
        return False, "rclone not installed/configured on Termux"
    cmd = [rclone_path, "copy", backup_path, remote, "--create-empty-src-dirs", "--transfers", "1", "--checkers", "2"]
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
    if result.returncode != 0:
        err = (result.stderr or result.stdout or "").strip()
        return False, err[-500:] or f"rclone exited {result.returncode}"
    return True, f"Uploaded to {remote}"


def run_daily_backup(reason="manual"):
    backup_path = create_cloud_bot_backup(reason)
    uploaded, upload_msg = upload_backup_to_google_drive(backup_path)
    size_mb = os.path.getsize(backup_path) / (1024 * 1024)
    if uploaded:
        summary = f"Backup uploaded to Google Drive | {os.path.basename(backup_path)} | {size_mb:.1f} MB"
        status = set_backup_status("uploaded", summary, path=backup_path, drive=google_drive_backup_remote(), size_mb=round(size_mb, 2))
        send_msg("Option King AI backup uploaded to Google Drive\n" + summary)
    else:
        summary = f"Backup saved locally, Google Drive upload pending | {upload_msg}"
        status = set_backup_status("local_only", summary, path=backup_path, drive=google_drive_backup_remote(), size_mb=round(size_mb, 2))
        send_msg("Option King AI backup saved locally\n" + summary)
    gui_log(status["summary"])
    return status


