            _okai_ai_bt_signal_meta[_okai_ai_bt_position_key_from_parts(day, clock_text, signal)] = meta
            _okai_ai_bt_signal_meta[_okai_ai_bt_position_key_from_parts("", clock_text, signal)] = meta

        if not decision.get("take_trade"):
            return None, "NONE", meta["ai_score"]
        trade_type = str(best.get("trade_type") or "").upper()
        if trade_type not in {"FULL", "HALF"}:
