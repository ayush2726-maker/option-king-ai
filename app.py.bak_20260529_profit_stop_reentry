def place_paper_trade(signal, premium, trade_type, option):
    trade_type = normalize_trade_type(trade_type)
    if not new_entries_allowed():
        gui_log(f"Entry blocked near EOD | Cutoff {entry_cutoff_time().strftime('%H:%M')} | Trade end {get_trade_end_time().strftime('%H:%M')}")
        update_trade_suggestion(None, "NONE", 0, 0, "Entry blocked near EOD", last_nifty_price)
        return
    if position is not None:
        gui_log("Entry blocked: position already open")
        return
    lot_size = int(option.get("lot_size", FAST_LOT_SIZE))
    qty = get_qty(premium, trade_type, lot_size)
    if qty <= 0:
        gui_log("Not enough capital for selected option")
        return

    if is_live_mode():
        ok, reason = live_preflight_checks()
        if not ok:
            gui_log(f"LIVE ENTRY BLOCKED | {reason}")
            send_msg(f"LIVE ENTRY BLOCKED\nReason: {reason}\nSignal: {signal} {trade_type}\nSymbol: {option.get('symbol')}")
            return
        order_id, response, _params = place_live_order(option, "BUY", qty, f"strategy {signal} {trade_type}")
        return _open_position_after_entry(signal, premium, trade_type, option, qty, "LIVE", order_id, response)

    return _open_position_after_entry(signal, premium, trade_type, option, qty, "PAPER")


def close_position(exit_price, reason):
    global position, capital, daily_pnl
    if position is None:
        return
    exit_qty = int(position["qty"])
    mode = position.get("mode", trade_mode())
    if mode == "LIVE":
        try:
            order_id, response, _params = place_live_order(position.get("option") or {}, "SELL", exit_qty, reason)
            position["live_exit_order_id"] = order_id
            position["live_exit_order_response"] = response
        except Exception as exc:
            gui_log(f"LIVE EXIT FAILED | Position kept open | {exc}")
            send_msg(
                "LIVE EXIT FAILED - MANUAL ACTION REQUIRED\n"
                f"Symbol: {position.get('option', {}).get('symbol', 'DEMO')}\n"
                f"Qty: {exit_qty}\nReason: {reason}\nError: {exc}"
            )
            return None

    gross_pnl = (exit_price - position["entry"]) * exit_qty
    charges = position_exit_charges(exit_price, exit_qty)
    net_pnl = gross_pnl - charges["total"]
    capital += net_pnl
    daily_pnl += net_pnl
    update_trade_stats(net_pnl)
    record_trade(exit_price, gross_pnl, charges, net_pnl, reason)
    register_reentry_block(reason, net_pnl)
    title = "LIVE EXIT" if mode == "LIVE" else "PAPER EXIT"
    msg = (
        f"{title}\nReason: {reason}\nSymbol: {position.get('option', {}).get('symbol', 'DEMO')}\n"
        f"Exit: {exit_price:.2f}\nGross P&L: {gross_pnl:.2f}\nCharges: {charges['total']:.2f}\n"
        f"Net P&L: {net_pnl:.2f}\nCapital: {capital:.2f}"
    )
    if position.get("live_exit_order_id"):
        msg += f"\nExit Order ID: {position.get('live_exit_order_id')}"
    position = None
    gui_log(msg)
    send_msg(msg)
    return net_pnl


def check_partial_exit():
    global capital, daily_pnl
    if position is None or position.get("partial_done"):
        return
    entry = position["entry"]
    ltp = position["ltp"]
    profit_percent = ((ltp - entry) / entry) * 100
    partial_trigger = (EXPIRY_TARGET_PERCENT if is_expiry_day() else TARGET_PERCENT) + 5
    if profit_percent < partial_trigger:
        return
    lot_size = get_position_lot_size()
    current_qty = int(position.get("qty", 0) or 0)
    if current_qty < lot_size * 2:
        return
    exit_lots = max(1, (current_qty // lot_size) // 2)
    exit_qty = exit_lots * lot_size
    if exit_qty <= 0 or current_qty - exit_qty < lot_size:
        return
    mode = position.get("mode", trade_mode())
    live_exit_order_id = ""
    if mode == "LIVE":
        try:
            live_exit_order_id, _response, _params = place_live_order(position.get("option") or {}, "SELL", exit_qty, "PARTIAL EXIT")
        except Exception as exc:
            gui_log(f"LIVE PARTIAL EXIT FAILED | Position kept full | {exc}")
            send_msg(
                "LIVE PARTIAL EXIT FAILED - MANUAL ACTION REQUIRED\n"
                f"Symbol: {position.get('option', {}).get('symbol', 'DEMO')}\n"
                f"Qty: {exit_qty}\nError: {exc}"
            )
            return
    gross_pnl = (ltp - entry) * exit_qty
    charges = position_exit_charges(ltp, exit_qty)
    net_pnl = gross_pnl - charges["total"]
    capital += net_pnl
    daily_pnl += net_pnl
    position["qty"] -= exit_qty
    position["closed_qty"] = int(position.get("closed_qty", 0) or 0) + exit_qty
    position["partial_done"] = True
    msg = f"{mode} PARTIAL EXIT | Qty: {exit_qty} | Exit: {ltp:.2f} | Gross: {gross_pnl:.2f} | Charges: {charges['total']:.2f} | Net: {net_pnl:.2f}"
    if live_exit_order_id:
        msg += f" | Order {live_exit_order_id}"
    gui_log(msg)
    send_msg(msg)
    save_trade_event("PARTIAL_EXIT", {
        "mode": mode,
        "trade_id": position.get("trade_id", ""),
        "trade_type": position.get("trade_type", "FULL"),
        "signal": position["signal"],
        "option": position.get("option"),
        "entry": entry,
        "exit": ltp,
        "ltp": ltp,
        "qty": exit_qty,
        "pnl": net_pnl,
        "gross_pnl": gross_pnl,
        "charges": charges,
        "net_pnl": net_pnl,
        "reason": "PARTIAL EXIT",
        "live_exit_order_id": live_exit_order_id,
    })


def manual_order(payload):
    if position is not None and str(payload.get("side", "BUY")).upper() == "BUY":
        raise RuntimeError("Position already open. Close it before manual BUY.")
    side = str(payload.get("side", "BUY") or "BUY").upper()
    if side == "SELL":
        if position is None:
            raise RuntimeError("No open position to sell")
        option = position.get("option") or {}
        premium = get_ltp(option.get("exchange"), option.get("symbol"), option.get("token")) or position.get("ltp") or position.get("entry")
        result = close_position(float(premium), "MANUAL SELL")
        return {"message": "manual sell requested", "pnl": result}

    signal = str(payload.get("signal") or payload.get("option_type") or "").upper()
    if signal not in {"CE", "PE"}:
        raise RuntimeError("Manual order signal must be CE or PE")
    trade_type = normalize_trade_type(payload.get("trade_type", "FULL"))
    spot = float(payload.get("spot") or last_nifty_price or get_nifty_price() or 0)
    if spot <= 0:
        raise RuntimeError("NIFTY spot unavailable")
    option = get_best_affordable_option(signal, spot)
    if option is None:
        raise RuntimeError(last_option_selection_reason)
    if payload.get("strike"):
        wanted = int(float(payload.get("strike")))
        master = get_master()
        df = master[
            (master["name"] == "NIFTY")
            & (master["exch_seg"] == "NFO")
            & (master["instrumenttype"].str.contains("OPT", na=False))
            & (master["symbol"].str.endswith(signal))
        ].copy()
        df["expiry_dt"] = parse_expiry_series(df["expiry"])
        df["strike_num"] = pd.to_numeric(df["strike"], errors="coerce") / 100
        df = df.dropna(subset=["expiry_dt", "strike_num"])
        df = df[(df["expiry_dt"] >= pd.Timestamp.today().normalize()) & (df["strike_num"] == wanted)].sort_values("expiry_dt")
        if df.empty:
            raise RuntimeError(f"Manual strike not found: {wanted}{signal}")
        row = df.iloc[0]
        option = {
            "symbol": row["symbol"],
            "token": row["token"],
            "exchange": row["exch_seg"],
            "strike": wanted,
            "lot_size": int(float(row["lotsize"])),
            "priority": -1,
        }
        option["premium"] = get_ltp(option["exchange"], option["symbol"], option["token"])
        if option["premium"] is None:
            raise RuntimeError("Manual strike LTP unavailable")
        option["cost"] = option["premium"] * option["lot_size"]
    premium = float(payload.get("premium") or option.get("premium") or 0)
    if premium <= 0:
        raise RuntimeError("Manual premium unavailable")
    option["premium"] = premium
    qty = int(float(payload.get("qty") or 0))
    lot_size = int(option.get("lot_size", FAST_LOT_SIZE))
    if qty > 0:
        qty = (qty // lot_size) * lot_size
        if qty <= 0:
            raise RuntimeError(f"Manual qty must be at least one lot: {lot_size}")
    else:
        qty = get_qty(premium, trade_type, lot_size)
    qty, _manual_capped = cap_qty_to_order_limit(qty, lot_size, "MANUAL")
    qty = risk_limited_qty(qty, premium, lot_size, "MANUAL")
    if qty <= 0:
        raise RuntimeError("Manual qty/capital blocked")
    if is_live_mode():
        ok, reason = live_preflight_checks()
        if not ok:
            raise RuntimeError(reason)
        order_id, response, _params = place_live_order(option, "BUY", qty, f"manual {signal} {trade_type}")
        _open_position_after_entry(signal, premium, trade_type, option, qty, "LIVE", order_id, response)
    else:
        _open_position_after_entry(signal, premium, trade_type, option, qty, "PAPER")
    return {"message": f"manual {trade_mode()} buy placed", "symbol": option.get("symbol"), "qty": qty}


