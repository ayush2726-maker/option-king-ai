                key = f"{signal}_{hour:02d}_edge"
                edge_rules[key] = edge
                if edge["grade"] in {"GOOD", "STRONG"}:
                    best_windows.append(edge)

        best_windows.sort(
            key=lambda item: (
                1 if item.get("grade") == "STRONG" else 0,
                float(item.get("profit_factor", 0) or 0),
                float(item.get("net", 0) or 0),
                int(item.get("sample", 0) or 0),
            ),
            reverse=True,
        )
        edge_summary = "; ".join(
            f"{item['signal']} {int(item['hour']):02d}:00 {item['grade']} WR {item['win_rate'] * 100:.0f}%"
