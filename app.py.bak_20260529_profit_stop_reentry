    symbol = str((option or {}).get("symbol") or "")
    current = _okai_quality_float(premium, 0)
    result = {
        "premium_momentum_ok": False,
        "premium_momentum_reason": "premium data unavailable",
        "premium_move_percent": 0.0,
        "premium_extension_percent": 0.0,
    }
    if current <= 0:
        return result
    try:
        ok, reason = _okai_cp_option_premium_momentum_ok(signal, option, current)
        result["premium_momentum_ok"] = bool(ok)
        result["premium_momentum_reason"] = str(reason)
    except Exception as exc:
        result["premium_momentum_reason"] = f"premium momentum error: {str(exc)[:80]}"

    hist = list(strict_option_premium_history.get(symbol, [])) if symbol else []
    values = [_okai_quality_float(item[1], 0) for item in hist if _okai_quality_float(item[1], 0) > 0]
    if len(values) >= 2:
        previous = values[-2]
        if previous > 0:
            result["premium_move_percent"] = round(((current - previous) / previous) * 100, 2)
        recent_base = min(values[:-1] or values)
        if recent_base > 0:
            result["premium_extension_percent"] = round(((current - recent_base) / recent_base) * 100, 2)
        early_floor = _okai_config_float("trade_quality_min_premium_move_percent", -0.75, -5.0, 5.0)
        if not result["premium_momentum_ok"] and result["premium_move_percent"] >= early_floor:
            result["premium_momentum_ok"] = True
            result["premium_momentum_reason"] = (
                f"early premium acceptable {result['premium_move_percent']:.2f}% >= {early_floor:.2f}%"
            )
    return result


def _okai_quality_backtest_premium(option):
    result = {
        "premium_momentum_ok": True,
        "premium_momentum_reason": "backtest premium proxy OK",
        "premium_move_percent": 0.0,
        "premium_extension_percent": 0.0,
    }
    try:
        option_df = option.get("option_df")
        entry_index = int(option.get("entry_option_index", 0) or 0)
        current = _okai_quality_float(option.get("raw_premium", option.get("premium")), 0)
        if option_df is None or option_df.empty or entry_index <= 0 or current <= 0:
            result["premium_momentum_ok"] = False
            result["premium_momentum_reason"] = "backtest premium candle unavailable"
            return result
        previous = _okai_quality_float(option_df.iloc[max(0, entry_index - 1)].get("close"), 0)
        lookback = option_df.iloc[max(0, entry_index - 5): entry_index + 1]
        base = _okai_quality_float(lookback["close"].min(), previous)
        if previous > 0:
            result["premium_move_percent"] = round(((current - previous) / previous) * 100, 2)
        if base > 0:
            result["premium_extension_percent"] = round(((current - base) / base) * 100, 2)
        min_move = _okai_config_float("trade_quality_min_premium_move_percent", -0.75, -5.0, 5.0)
        result["premium_momentum_ok"] = result["premium_move_percent"] >= min_move
        result["premium_momentum_reason"] = (
            f"backtest premium momentum {result['premium_move_percent']:.2f}%"
            if result["premium_momentum_ok"]
            else f"backtest premium momentum weak {result['premium_move_percent']:.2f}%<{min_move:.2f}%"
        )
        return result
    except Exception as exc:
        result["premium_momentum_ok"] = False
        result["premium_momentum_reason"] = f"backtest premium quality error: {str(exc)[:80]}"
        return result


def _okai_build_trade_quality(signal, premium=None, option=None, df=None, price=None, require_premium=True, backtest=False):
    setup, work, setup_price = _okai_quality_setup(signal, df, price)
    score = _okai_quality_int(setup.get("score", setup.get("weighted_score", 0)), 0)
    confidence = _okai_quality_int(setup.get("confidence", 0), 0)
    fake = _okai_quality_int(setup.get("fake_breakout_probability", 0), 0)
    regime = str(setup.get("market_regime") or ((setup.get("regime") or {}).get("regime", "")) or "--").upper()
    entry_type = str(setup.get("entry_type") or "NONE").upper()

    volume_score = _okai_quality_component(setup, "volume_spike")
    chain_score = _okai_quality_component(setup, "option_chain_support")
    oi_score = _okai_quality_component(setup, "oi_buildup")
    atr_score = _okai_quality_component(setup, "atr_volatility")
    candle_score = _okai_quality_component(setup, "strong_candle_close")
    vwap_score = _okai_quality_component(setup, "vwap_alignment")
    ema_score = _okai_quality_component(setup, "ema_alignment")
    chain_missing = _okai_quality_component_missing(setup, "option_chain_support")
    oi_missing = _okai_quality_component_missing(setup, "oi_buildup")
    atr_missing = _okai_quality_component_missing(setup, "atr_volatility")

    timing_ok, timing_reason = _okai_quality_timing_check(signal, setup, work, setup_price)
    premium_info = _okai_quality_live_premium(signal, option, premium) if require_premium else {
        "premium_momentum_ok": True,
        "premium_momentum_reason": "premium check deferred",
        "premium_move_percent": 0.0,
        "premium_extension_percent": 0.0,
    }
    max_extension = _okai_config_float("trade_quality_max_premium_extension_percent", 12.0, 2.0, 60.0)
    min_a_score = _okai_config_float("trade_quality_min_a_score", 70, 1, 100)
    min_aplus_score = _okai_config_float("trade_quality_min_aplus_score", 90, 1, 100)
    max_fake_a = _okai_config_float("trade_quality_max_fake_a", 45, 5, 80)
    max_fake_aplus = _okai_config_float("trade_quality_max_fake_aplus", 18, 1, 80)
    min_volume_score = _okai_config_float("trade_quality_min_volume_score", 7, 0, 14)
    min_chain_score = _okai_config_float("trade_quality_min_chain_score", 8, 0, 12)
    min_oi_score = _okai_config_float("trade_quality_min_oi_score", 5, 0, 8)
    min_atr_score = _okai_config_float("trade_quality_min_atr_score", 3, 0, 10)
    min_candle_score = _okai_config_float("trade_quality_min_candle_score", 6, 0, 10)

    blocks = []
    if not setup:
        blocks.append("quality setup unavailable")
    if score < min_a_score:
        blocks.append(f"quality score {score}<{min_a_score:.0f}")
    if "TREND" not in regime:
        blocks.append(f"not clean trend: {regime or '--'}")
    if any(term in regime for term in ("SIDEWAYS", "CHOPPY", "RANGE", "MIXED_LOW_VOLUME")):
        blocks.append(f"sideways/choppy regime: {regime}")
    if fake > max_fake_a:
        blocks.append(f"fake breakout {fake}%>{max_fake_a:.0f}%")
    if volume_score < min_volume_score:
        blocks.append(f"volume {volume_score}/14<{min_volume_score:.0f}")
    if chain_score < min_chain_score and not chain_missing:
        blocks.append(f"chain {chain_score}/12<{min_chain_score:.0f}")
    if oi_score < min_oi_score and not oi_missing:
        blocks.append(f"OI {oi_score}/8<{min_oi_score:.0f}")
    if atr_score < min_atr_score and not atr_missing:
        blocks.append(f"ATR {atr_score}/10<{min_atr_score:.0f}")
    if candle_score < min_candle_score:
        blocks.append(f"continuation candle {candle_score}/10<{min_candle_score:.0f}")
    if vwap_score < 10 or ema_score < 10:
        blocks.append("pullback/continuation hold incomplete")
    if not timing_ok:
        blocks.append(timing_reason)
    if require_premium and not premium_info.get("premium_momentum_ok"):
        blocks.append(premium_info.get("premium_momentum_reason") or "premium momentum missing")
    if premium_info.get("premium_extension_percent", 0) > max_extension:
        blocks.append(f"stretched premium {premium_info['premium_extension_percent']:.2f}%>{max_extension:.2f}%")
    revenge = _okai_quality_direction_block(signal)
    if revenge:
        blocks.append(revenge)

    pressure_ok = (
        volume_score >= min_volume_score
        and (chain_missing or chain_score >= min_chain_score)
        and (oi_missing or oi_score >= min_oi_score)
    )
    pullback_hold = timing_ok and vwap_score >= 10 and ema_score >= 10
    continuation_ok = candle_score >= min_candle_score and (atr_missing or atr_score >= min_atr_score)
    if not pressure_ok:
        blocks.append("breakout pressure buildup incomplete")
    if not pullback_hold:
        blocks.append("pullback hold not confirmed")
    if not continuation_ok:
        blocks.append("continuation confirmation incomplete")

    if (
        score >= min_aplus_score
        and fake <= max_fake_aplus
        and volume_score >= 12
        and not chain_missing and chain_score >= 10
        and not oi_missing and oi_score >= 6
        and atr_score >= 7 and candle_score >= 8 and not blocks
    ):
        grade = "A+"
    elif score >= min_a_score and fake <= max_fake_a and not blocks:
        grade = "A"
    elif score >= 78:
        grade = "B"
    else:
        grade = "C"

    approved = grade in _okai_quality_allowed_grades() and not blocks
    payload = {
        "approved": approved,
        "grade": grade,
        "signal": str(signal or "").upper(),
        "score": score,
        "confidence": confidence,
        "fake_breakout_probability": fake,
        "market_regime": regime,
        "entry_type": entry_type,
        "premium_move_percent": premium_info.get("premium_move_percent", 0.0),
        "premium_extension_percent": premium_info.get("premium_extension_percent", 0.0),
        "premium_momentum_reason": premium_info.get("premium_momentum_reason", ""),
        "breakout_pressure_buildup": pressure_ok,
        "pullback_hold": pullback_hold,
        "continuation_confirmation": continuation_ok,
        "timing_reason": timing_reason,
        "components": {
            "volume": volume_score,
            "chain": chain_score,
            "oi": oi_score,
            "atr": atr_score,
            "candle": candle_score,
            "vwap": vwap_score,
            "ema": ema_score,
            "chain_missing": chain_missing,
            "oi_missing": oi_missing,
            "atr_missing": atr_missing,
        },
        "blocks": list(dict.fromkeys([str(item) for item in blocks if item]))[:8],
        "backtest": bool(backtest),
        "created_at": market_now().isoformat(timespec="seconds"),
    }
    return approved, payload


