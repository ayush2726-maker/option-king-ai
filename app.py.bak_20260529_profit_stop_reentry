def prepare_weighted_backtest_df(df):
    work = df.copy()
    for col in ["open", "high", "low", "close", "volume"]:
        if col in work.columns:
            work[col] = pd.to_numeric(work[col], errors="coerce")
    if "volume" not in work.columns:
        work["volume"] = 0
    if "EMA9" not in work.columns:
        work["EMA9"] = work["close"].ewm(span=9).mean()
    if "EMA21" not in work.columns:
        work["EMA21"] = work["close"].ewm(span=21).mean()
    if "VWAP" not in work.columns:
        work["VWAP"] = compute_vwap_or_session_average(work)
    if "SUPERTREND" not in work.columns or "SUPERTREND_DIR" not in work.columns:
        work = add_supertrend(work)

    aliases = {
        "vwap": "VWAP",
        "ema9": "EMA9",
        "ema21": "EMA21",
        "supertrend": "SUPERTREND",
        "supertrend_dir": "SUPERTREND_DIR",
    }
    for lower_name, upper_name in aliases.items():
        if upper_name in work.columns and lower_name not in work.columns:
            work[lower_name] = work[upper_name]
        if lower_name in work.columns and upper_name not in work.columns:
            work[upper_name] = work[lower_name]
    return work


def weighted_indicator_snapshot(df, price=None):
    work = prepare_weighted_backtest_df(df)
