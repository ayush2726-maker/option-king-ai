def _okai_learning_profit_factor(rows):
    wins = sum(_okai_learning_trade_pnl(row) for row in rows if _okai_learning_trade_pnl(row) > 0)
    losses = abs(sum(_okai_learning_trade_pnl(row) for row in rows if _okai_learning_trade_pnl(row) <= 0))
    if losses <= 0:
        return 99.0 if wins > 0 else 0.0
    return wins / losses


def _okai_learning_edge_from_bucket(rows):
    sample = len(rows)
    wr = _okai_learning_win_rate(rows)
    net = _okai_learning_net(rows)
    avg = net / sample if sample else 0.0
    pf = _okai_learning_profit_factor(rows)
    early_fails = sum(
        1 for row in rows
        if "EARLY EXIT" in _okai_learning_reason(row) or "PREMIUM FAILED" in _okai_learning_reason(row)
    )
    trailing_or_sl_profit = sum(
        1 for row in rows
        if _okai_learning_trade_pnl(row) > 0 and ("SL HIT" in _okai_learning_reason(row) or "TRAIL" in _okai_learning_reason(row))
    )
    return {
        "sample": sample,
        "win_rate": round(wr, 3),
        "net": round(net, 2),
        "avg": round(avg, 2),
        "profit_factor": round(pf, 2),
        "early_fails": early_fails,
        "trail_wins": trailing_or_sl_profit,
    }


def _okai_learning_edge_grade(edge):
    sample = int(edge.get("sample", 0) or 0)
    wr = float(edge.get("win_rate", 0) or 0)
    net = float(edge.get("net", 0) or 0)
    avg = float(edge.get("avg", 0) or 0)
    pf = float(edge.get("profit_factor", 0) or 0)
    early_fails = int(edge.get("early_fails", 0) or 0)
    early_fail_rate = early_fails / sample if sample else 1.0
    if sample >= 5 and wr >= 0.65 and net > 0 and avg > 0 and pf >= 1.45 and early_fail_rate <= 0.35:
        return "STRONG"
    if sample >= 3 and wr >= 0.58 and net > 0 and avg > 0 and pf >= 1.15 and early_fail_rate <= 0.45:
        return "GOOD"
    return "NONE"


def _okai_rebuild_local_learning(force=False):
    profile = _OKAI_EDGE_BASE_REBUILD_LOCAL_LEARNING(force)
    try:
