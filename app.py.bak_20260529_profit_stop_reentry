def _okai_safe_do_post(self):
    if not self.authorized():
        self.send_json({"ok": False, "error": "unauthorized"}, 401)
        return
    path = urlparse(self.path).path
    if path == "/mode":
        body = self.read_body()
        mode = str(body.get("trade_mode", body.get("mode", "PAPER")) or "PAPER").upper()
        confirm = str(body.get("confirm", "") or "").upper()
        try:
            if mode == "LIVE" and confirm != "CONFIRM":
                self.send_json({
                    "ok": False,
                    "error": "LIVE mode requires confirmation",
                    "message": "Send confirm=CONFIRM or use Telegram /mode live then /mode live CONFIRM",
                }, 400)
                return
            if mode == "LIVE":
                if not safe_check_internet(force=True):
                    raise RuntimeError("Internet offline")
                config["safe_live_manual_session_confirmed"] = True
                data = set_trade_mode("LIVE", True)
            else:
                config["safe_live_manual_session_confirmed"] = False
                data = set_trade_mode("PAPER", False)
            self.send_json({"ok": True, "message": "trade mode updated", "data": data})
            return
        except Exception as exc:
            self.send_json({"ok": False, "error": str(exc)}, 400)
            return
    return _OKAI_SAFE_BASE_HANDLER_DO_POST(self)


