    premium_quality = _okai_quality_backtest_premium(option)
    max_extension = _okai_config_float("trade_quality_max_premium_extension_percent", 12.0, 2.0, 60.0)
    if not premium_quality.get("premium_momentum_ok"):
        notes.append("quality blocked: " + premium_quality.get("premium_momentum_reason", "premium momentum weak"))
