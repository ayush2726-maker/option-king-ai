    symbol = str(option.get("symbol") or "NO_SYMBOL")
    bucket = int(_safe_now_ts() // max(30, _safe_config_int("safe_signal_bucket_seconds", 60, 30, 300)))
    return "|".join([str(signal).upper(), normalize_trade_type(trade_type), symbol, str(int(score or 0)), str(bucket), str(reason or "strategy")])


def reserve_order_signal(signal, trade_type, option=None, reason="strategy"):
    now = _safe_now_ts()
    key = build_order_signal_key(signal, trade_type, option, reason)
    block_seconds = _safe_config_float("safe_duplicate_signal_block_seconds", 120, 20, 900)
    if safe_runtime.get("pending_order_key") == key and now - float(safe_runtime.get("pending_order_ts", 0) or 0) < block_seconds:
        return False, f"duplicate pending order blocked: {key}", key
    if safe_runtime.get("last_signal_key") == key and now - float(safe_runtime.get("last_signal_ts", 0) or 0) < block_seconds:
        return False, f"duplicate signal cooldown active: {key}", key
    safe_runtime["pending_order_key"] = key
    safe_runtime["pending_order_ts"] = now
    return True, "OK", key


