            "reason": atr_reason,
        },
    }

    raw_score = sum(int(item["score"]) for item in components.values())
    score = int(_w_clamp(raw_score, 0, 100))
    confidence = score
    modifiers = []
    signal_dir = _w_direction(signal)

    if regime.get("direction") == signal_dir:
        confidence += 5
        modifiers.append("regime aligned")
    elif regime.get("direction") not in {"NEUTRAL", signal_dir}:
        confidence -= 8
        modifiers.append("regime opposite")

    if mtf.get("bias") == signal_dir:
        confidence += min(6, 2 + int(mtf.get("score", 0) or 0) * 2)
        modifiers.append("MTF aligned")
    elif mtf.get("bias") not in {"NEUTRAL", signal_dir}:
        confidence -= 7
        modifiers.append("MTF opposite")

    if structure.get("bias") == signal_dir:
        confidence += 4
        modifiers.append("structure aligned")
    elif structure.get("bias") not in {"NEUTRAL", signal_dir}:
