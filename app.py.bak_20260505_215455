    gui_log(f"Opening ORB set | {ORB_START.strftime('%H:%M')}-{ORB_END.strftime('%H:%M')} | High {orb_high:.2f} | Low {orb_low:.2f}")


def predict_trend():
    df = get_indicators()
    if df is None or len(df) < 20:
        return "NEUTRAL"
    last = df.iloc[-1]
    if last["EMA9"] > last["EMA21"]:
        return "UPTREND"
    if last["EMA9"] < last["EMA21"]:
        return "DOWNTREND"
    return "NEUTRAL"


def candle_body_ratio(candle):
    candle_range = float(candle["high"] - candle["low"])
    if candle_range <= 0:
        return 0
    return abs(float(candle["close"] - candle["open"])) / candle_range


def has_strong_two_candle_momentum(c1, c2, signal):
    if signal == "CE":
        same_direction = c1["close"] > c1["open"] and c2["close"] > c2["open"]
    else:
        same_direction = c1["close"] < c1["open"] and c2["close"] < c2["open"]
    if not same_direction:
        return False
    return candle_body_ratio(c1) >= MIN_CANDLE_BODY_RATIO and candle_body_ratio(c2) >= MIN_CANDLE_BODY_RATIO


def supertrend_filter_enabled():
    return bool(config.get("use_supertrend_filter", USE_SUPERTREND_FILTER))


def choose_rule_signal(price, vwap, ema9, ema21, trend, supertrend_dir, c1, c2, ce_score, pe_score):
    ce_breakout = price > (orb_high + ORB_BREAK_BUFFER_POINTS) and c2["close"] > orb_high
    pe_breakout = price < (orb_low - ORB_BREAK_BUFFER_POINTS) and c2["close"] < orb_low
    ema_gap = abs(ema9 - ema21)
    vwap_distance = abs(price - vwap)
    if ema_gap < MIN_EMA_GAP_POINTS and vwap_distance < MIN_VWAP_DISTANCE_POINTS:
        return None, "NONE", 0, "Choppy market: EMA/VWAP too close"
    if supertrend_filter_enabled():
        if ce_score > pe_score and supertrend_dir != "UP":
            return None, "NONE", 0, f"CE blocked: Supertrend {supertrend_dir}"
        if pe_score > ce_score and supertrend_dir != "DOWN":
            return None, "NONE", 0, f"PE blocked: Supertrend {supertrend_dir}"

    ce_momentum = has_strong_two_candle_momentum(c1, c2, "CE")
    pe_momentum = has_strong_two_candle_momentum(c1, c2, "PE")
    if ce_score >= FULL_SCORE_REQUIRED and ce_score > pe_score and ce_breakout and ce_momentum:
        return "CE", "FULL", 90, "Full CE: ORB breakout with trend and strong candles"
    if pe_score >= FULL_SCORE_REQUIRED and pe_score > ce_score and pe_breakout and pe_momentum:
        return "PE", "FULL", 90, "Full PE: ORB breakdown with trend and strong candles"
    if ce_score >= HALF_SCORE_REQUIRED and ce_score > pe_score and ce_breakout:
        return "CE", "HALF", 70, "Half CE: ORB breakout, waiting for full confirmation"
    if pe_score >= HALF_SCORE_REQUIRED and pe_score > ce_score and pe_breakout:
        return "PE", "HALF", 70, "Half PE: ORB breakdown, waiting for full confirmation"
    if max(ce_score, pe_score) >= HALF_SCORE_REQUIRED:
        return None, "NONE", 0, "Setup blocked: score ok but ORB breakout/momentum not strong"
    return None, "NONE", 0, "No setup"


