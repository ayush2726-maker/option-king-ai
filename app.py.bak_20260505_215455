    trades_taken += 1
    msg = f"PAPER ENTRY\nType: {trade_type}\nSignal: {signal}\nSymbol: {option['symbol']}\nEntry: {premium:.2f}\nQty: {qty}\nSL: {position['sl']:.2f}\nTarget: {position['target']:.2f}"
